{%- liquid
  assign section_classes = 'boc-contact-section boc-contact-final boc-contact-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-contact-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-contact-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-contact-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-contact-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-vineyard.jpg' | asset_url
  assign form_anchor = section.settings.form_anchor | default: 'boc-contact-form'
  assign phone = section.settings.phone_number | default: settings.boc_general_phone
  assign phone_href = phone | replace: ' ', '' | replace: '(', '' | replace: ')', ''
-%}

<section
  id="boc-contact-final-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-contact
  style="
    --boc-ct-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-ct-final-width: {{ section.settings.content_width }}px;
    --boc-ct-final-overlay: {{ section.settings.overlay_color }};
    --boc-ct-final-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  <div class="boc-contact-final__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="430">
    {%- endif -%}
  </div>
  <div class="boc-contact-final__overlay" aria-hidden="true"></div>
  <div class="boc-contact-final__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-contact-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-contact-final__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="#{{ form_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}" data-boc-contact-scroll>{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank and phone != blank -%}
        <a href="tel:{{ phone_href }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}">{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Contact Final CTA",
  "tag": "section",
  "class": "boc-contact-final-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "form_anchor", "label": "Form anchor", "default": "boc-contact-form" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 55 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 320, "max": 720, "step": 20, "unit": "px", "default": 440 },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 760 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Still need help?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We would love to hear from you." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Send a general enquiry or speak directly with the team responsible for your booking, membership, event or order." },
    { "type": "header", "content": "Primary button" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Send an enquiry" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "header", "content": "Phone button" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Call 03 5962 6899" },
    { "type": "text", "id": "phone_number", "label": "Phone number", "default": "03 5962 6899", "info": "Used for tel: link. Display label is editable separately above." },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" }
  ],
  "presets": [{ "name": "BOC — Contact Final CTA" }]
}
{% endschema %}
