{%- liquid
  assign nav_classes = 'boc-whats-on-nav'
  unless section.settings.sticky_enabled
    assign nav_classes = nav_classes | append: ' boc-whats-on-nav--disabled'
  endunless
  unless section.settings.section_enabled
    assign nav_classes = nav_classes | append: ' boc-whats-on-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign nav_classes = nav_classes | append: ' boc-whats-on-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign nav_classes = nav_classes | append: ' boc-whats-on-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign nav_classes = nav_classes | append: ' boc-whats-on-section--hide-mobile'
  endunless
-%}

<nav
  class="{{ nav_classes }}"
  aria-label="{{ section.settings.aria_label | default: 'Page navigation' }}"
  data-boc-whats-on-nav
  data-tracking="{{ section.settings.active_tracking }}"
  style="--boc-wo-nav-bg: {{ section.settings.background_color }}; --boc-wo-nav-text: {{ section.settings.text_color }}; --boc-wo-nav-active: {{ section.settings.active_color }};"
  data-boc-whats-on
>
  <div class="boc-whats-on-section__inner boc-whats-on-nav__inner">
    {%- for block in section.blocks -%}
      <a href="#{{ block.settings.anchor_id }}" class="boc-whats-on-nav__link" data-boc-whats-on-scroll {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
    {%- endfor -%}
  </div>
</nav>

{% schema %}
{
  "name": "BOC — WO Anchor Nav",
  "tag": "section",
  "class": "boc-whats-on-nav-section",
  "max_blocks": 8,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "checkbox", "id": "sticky_enabled", "label": "Enable sticky navigation", "default": true },
    { "type": "checkbox", "id": "active_tracking", "label": "Highlight active section on scroll", "default": true },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#212121" },
    { "type": "color", "id": "active_color", "label": "Active/hover colour", "default": "#B99E7E" },
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "What's On page navigation" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Link" },
        { "type": "text", "id": "anchor_id", "label": "Anchor ID", "default": "boc-whats-on-events" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — WO Anchor Nav",
      "blocks": [
        { "type": "link", "settings": { "label": "Upcoming events", "anchor_id": "boc-whats-on-events" } },
        { "type": "link", "settings": { "label": "Weddings & private events", "anchor_id": "boc-whats-on-celebrations" } },
        { "type": "link", "settings": { "label": "Our spaces", "anchor_id": "boc-whats-on-venues" } },
        { "type": "link", "settings": { "label": "Enquire", "anchor_id": "boc-whats-on-enquiry" } },
        { "type": "link", "settings": { "label": "Explore the Yarra Valley", "anchor_id": "boc-whats-on-discover" } }
      ]
    }
  ]
}
{% endschema %}
