{%- doc -%}
  Renders a testimonial card.

  @param {object} block - Testimonial block
  @param {object} settings - Section settings
  @param {string} [variant] - whats-on (default) or visit
{%- enddoc -%}

{%- liquid
  assign card_prefix = 'boc-whats-on-testimonials'
  if variant == 'visit'
    assign card_prefix = 'boc-visit-reviews'
  endif
-%}

<article class="{{ card_prefix }}__card" {{ block.shopify_attributes }}>
  {%- if settings.show_stars and block.settings.rating > 0 -%}
    <div class="{{ card_prefix }}__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
      {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
    </div>
  {%- endif -%}
  {%- if block.settings.quote != blank -%}
    <blockquote class="{{ card_prefix }}__quote">{{ block.settings.quote }}</blockquote>
  {%- endif -%}
  <cite class="{{ card_prefix }}__cite">
    {%- if block.settings.name != blank -%}{{ block.settings.name }}{%- endif -%}
    {%- if block.settings.context != blank -%} · {{ block.settings.context }}{%- endif -%}
  </cite>
</article>
