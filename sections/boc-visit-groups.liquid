{%- liquid
  assign section_classes = 'boc-visit-section boc-visit-groups boc-visit-section--standard'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-visit-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-visit-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-visit-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-visit-section--hide-mobile'
  endunless

  assign image_fallback = 'boc-estate-vineyard.jpg' | asset_url
  assign enquiry_url = section.settings.button_url | default: section.settings.group_enquiry_url | default: '/pages/contact'
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-visit-groups' }}"
  class="{{ section_classes }}"
  data-boc-visit
  style="
    --boc-v-bg: {{ section.settings.background_color }};
    --boc-v-text: {{ section.settings.text_color }};
    --boc-v-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-v-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-v-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-v-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-v-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-v-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-v-groups-img-h: {{ section.settings.image_height }}px;
    --boc-v-detail-border: {{ section.settings.detail_border_color }};
  "
>
  <div class="boc-visit-section__inner">
    <div class="boc-visit-groups__grid">
      <div class="boc-visit-groups__media">
        {%- if section.settings.image != blank -%}
          {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '(min-width: 980px) 50vw, 100vw' %}
        {%- else -%}
          <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1200" height="560">
        {%- endif -%}
      </div>
      <div class="boc-visit-groups__copy">
        {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="boc-visit-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
        {% render 'boc-detail-list', blocks: section.blocks, dark: true %}
        {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
          {%- if enquiry_url contains '#' -%}
            <a href="{{ enquiry_url }}" class="boc-btn boc-btn--{{ section.settings.button_style | default: 'light' }}" data-boc-visit-scroll
              {%- if section.settings.button_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
            >{{ section.settings.button_label }}</a>
          {%- else -%}
            {% render 'boc-button', label: section.settings.button_label, url: enquiry_url, style: section.settings.button_style | default: 'light', new_tab: section.settings.button_new_tab %}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Visit Groups",
  "tag": "section",
  "class": "boc-visit-groups-section",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-visit-groups" },
    { "type": "url", "id": "group_enquiry_url", "label": "Group enquiry URL", "default": "/pages/contact" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#B99E7E" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "detail_border_color", "label": "Detail border", "default": "rgba(255,255,255,0.35)" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "range", "id": "image_height", "label": "Image height", "min": 360, "max": 700, "step": 20, "unit": "px", "default": 560 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Groups of 11+" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bring the whole table." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Planning a birthday, team lunch or relaxed celebration? Our group experience combines shared seasonal food, estate wine and sweeping vineyard views." },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Enquire about groups" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"light","label":"Light"},{"value":"primary","label":"Primary"}],"default": "light" },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Detail" },
        { "type": "text", "id": "value", "label": "Value", "default": "Value" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Visit Groups",
      "blocks": [
        { "type": "detail", "settings": { "label": "Shared menu", "value": "Seasonal selection" } },
        { "type": "detail", "settings": { "label": "Wine pairing", "value": "Estate list available" } },
        { "type": "detail", "settings": { "label": "Large groups", "value": "Advance booking required" } }
      ]
    }
  ]
}
{% endschema %}
