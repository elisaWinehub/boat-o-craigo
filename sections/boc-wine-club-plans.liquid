{%- liquid
  assign section_classes = 'boc-wine-club-section boc-wine-club-plans boc-wine-club-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-wine-club-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-mobile'
  endunless

  assign anchor_id = section.settings.section_anchor_id | default: 'boc-wine-club-plans'
-%}

<section
  id="{{ anchor_id }}"
  class="{{ section_classes }}"
  data-boc-wine-club
  style="
    --boc-wc-bg: {{ section.settings.background_color }};
    --boc-wc-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-wc-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-wc-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-wc-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-wc-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-wc-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-wc-heading: {{ section.settings.heading_color }};
    --boc-wc-body: {{ section.settings.body_color }};
    --boc-wc-align-d: {{ section.settings.text_alignment_desktop }};
    --boc-wc-align-m: {{ section.settings.text_alignment_mobile }};
  "
>
  <div class="boc-wine-club-section__inner">
    <div class="boc-wine-club-section__head">
      <div class="boc-wine-club-section__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow boc-wine-club-section__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-wine-club-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.intro_body != blank -%}
        <p class="boc-wine-club-section__head-aside">{{ section.settings.intro_body }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="boc-wine-club-plans__grid">
        {%- for block in section.blocks -%}
          {% render 'boc-wine-club-plan-card', block: block %}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BOC — Wine Club Plans",
  "tag": "section",
  "class": "boc-wine-club-plans-section",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Standard width" },
        { "value": "narrow", "label": "Narrow width" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-wine-club-plans" },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 32 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 82 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Membership options" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your level." },
    { "type": "textarea", "id": "intro_body", "label": "Intro body", "default": "Every membership includes flexible wine selection, member-only pricing and access to the Boat O'Craigo community." },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#212121" },
    { "type": "color", "id": "body_color", "label": "Body colour", "default": "#575962" },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Desktop alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Mobile alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Membership plan",
      "settings": [
        { "type": "text", "id": "plan_name", "label": "Plan name", "default": "Discovery" },
        {
          "type": "select",
          "id": "tier_type",
          "label": "Tier type",
          "options": [
            { "value": "bronze", "label": "Bronze (Discovery)" },
            { "value": "silver", "label": "Silver (Cellar)" },
            { "value": "gold", "label": "Gold (Collector)" }
          ],
          "default": "bronze"
        },
        { "type": "color", "id": "tier_color_override", "label": "Tier colour override" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "10% off" },
        { "type": "text", "id": "bottle_quantity", "label": "Bottle quantity", "default": "3 bottles" },
        { "type": "text", "id": "frequency", "label": "Frequency", "default": "Quarterly" },
        { "type": "text", "id": "discount_percent", "label": "Discount percentage", "default": "10" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "Choose any 3 wines" },
        { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "10% member discount" },
        { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Complimentary tastings" },
        { "type": "text", "id": "benefit_4", "label": "Benefit 4", "default": "Early access to new releases" },
        { "type": "text", "id": "benefit_5", "label": "Benefit 5" },
        { "type": "text", "id": "benefit_6", "label": "Benefit 6" },
        { "type": "checkbox", "id": "featured", "label": "Featured plan", "default": false },
        { "type": "color", "id": "card_background", "label": "Card background", "default": "#FFFFFF" },
        { "type": "color", "id": "text_color", "label": "Text colour", "default": "#212121" },
        { "type": "header", "content": "Button" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Join Discovery" },
        {
          "type": "select",
          "id": "button_action_type",
          "label": "Button action type",
          "options": [
            { "value": "url", "label": "URL" },
            { "value": "product", "label": "Shopify product" },
            { "value": "page", "label": "Shopify page" },
            { "value": "app_block", "label": "App block placeholder" }
          ],
          "default": "url",
          "info": "Join buttons are placeholders until the Wine Club app or membership product architecture is confirmed."
        },
        { "type": "url", "id": "button_url", "label": "Button URL" },
        { "type": "product", "id": "button_product", "label": "Button product" },
        { "type": "page", "id": "button_page", "label": "Button page" },
        {
          "type": "text",
          "id": "app_block_note",
          "label": "App block note",
          "default": "Membership join action will connect to the Wine Club app when confirmed."
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "outline", "label": "Outline" },
            { "value": "accent", "label": "Accent" },
            { "value": "primary", "label": "Primary" },
            { "value": "light", "label": "Light" }
          ],
          "default": "outline"
        },
        { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Wine Club Plans",
      "blocks": [
        {
          "type": "plan",
          "settings": {
            "plan_name": "Discovery",
            "tier_type": "bronze",
            "badge_text": "10% off",
            "bottle_quantity": "3 bottles",
            "frequency": "Quarterly",
            "discount_percent": "10",
            "benefit_1": "Choose any 3 wines",
            "benefit_2": "10% member discount",
            "benefit_3": "Complimentary tastings",
            "benefit_4": "Early access to new releases",
            "button_label": "Join Discovery"
          }
        },
        {
          "type": "plan",
          "settings": {
            "plan_name": "Cellar",
            "tier_type": "silver",
            "badge_text": "Most popular · 20% off",
            "bottle_quantity": "6 bottles",
            "frequency": "Quarterly",
            "discount_percent": "20",
            "featured": true,
            "benefit_1": "Choose any 6 wines",
            "benefit_2": "20% member discount",
            "benefit_3": "Complimentary tastings",
            "benefit_4": "Priority access to club events",
            "button_label": "Join Cellar",
            "button_style": "accent"
          }
        },
        {
          "type": "plan",
          "settings": {
            "plan_name": "Collector",
            "tier_type": "gold",
            "badge_text": "30% off",
            "bottle_quantity": "12 bottles",
            "frequency": "Quarterly",
            "discount_percent": "30",
            "benefit_1": "Choose any 12 wines",
            "benefit_2": "30% member discount",
            "benefit_3": "Complimentary tastings",
            "benefit_4": "First access to museum wines",
            "button_label": "Join Collector"
          }
        }
      ]
    }
  ]
}
{% endschema %}
