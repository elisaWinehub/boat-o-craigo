{%- liquid
  assign section_classes = 'boc-whats-on-section boc-whats-on-discover boc-whats-on-section--standard'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-whats-on-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-mobile'
  endunless
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-whats-on-discover' }}"
  class="{{ section_classes }}"
  data-boc-whats-on
  style="
    --boc-wo-bg: {{ section.settings.background_color }};
    --boc-wo-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-wo-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-wo-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-wo-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-wo-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-wo-pb-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="boc-whats-on-section__inner">
    <div class="boc-whats-on-section__head">
      <div class="boc-whats-on-section__head-text">
        {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="boc-whats-on-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.intro_body != blank -%}<p class="boc-whats-on-section__head-aside">{{ section.settings.intro_body }}</p>{%- endif -%}
    </div>
    <div class="boc-whats-on-discover__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_url = block.settings.url
          if block.settings.page != blank
            assign card_url = block.settings.page.url
          elsif block.settings.article != blank
            assign card_url = block.settings.article.url
          endif
        -%}
        <a href="{{ card_url | default: '#' }}" class="boc-whats-on-feature-card boc-whats-on-feature-card--discover" style="--boc-wo-card-height: {{ block.settings.card_height | default: 430 }}px;" {{ block.shopify_attributes }}>
          <div class="boc-whats-on-feature-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="900" height="430">
            {%- else -%}
              <img src="{{ 'boc-estate-vineyard.jpg' | asset_url }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="900" height="430">
            {%- endif -%}
          </div>
          <div class="boc-whats-on-feature-card__overlay" aria-hidden="true"></div>
          <div class="boc-whats-on-feature-card__copy">
            {%- if block.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ block.settings.eyebrow }}</span>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h3 class="boc-whats-on-feature-card__heading">{{ block.settings.heading }}</h3>{%- endif -%}
            {%- if block.settings.link_label != blank -%}<span class="boc-home-text-link">{{ block.settings.link_label }}</span>{%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — WO Discover",
  "tag": "section",
  "class": "boc-whats-on-discover-section",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-whats-on-discover" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Beyond the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore the Yarra Valley." },
    { "type": "textarea", "id": "intro_body", "label": "Intro", "default": "Make a day or weekend of your visit with local wine, food and attractions throughout the Yarra Valley." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Discover card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Guide" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Card title" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore" },
        { "type": "url", "id": "url", "label": "URL" },
        { "type": "page", "id": "page", "label": "Page" },
        { "type": "article", "id": "article", "label": "Article" },
        { "type": "range", "id": "card_height", "label": "Card height", "min": 300, "max": 600, "step": 20, "unit": "px", "default": 430 }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — WO Discover",
      "blocks": [
        { "type": "card", "settings": { "eyebrow": "Guide", "heading": "Yarra Valley Wine Trail", "link_label": "Explore the trail" } },
        { "type": "card", "settings": { "eyebrow": "Local area", "heading": "Things to do nearby", "link_label": "Discover the region" } },
        { "type": "card", "settings": { "eyebrow": "Journal", "heading": "Stories from the vineyard", "link_label": "Read the journal" } }
      ]
    }
  ]
}
{% endschema %}
