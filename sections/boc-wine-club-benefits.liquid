{%- liquid
  assign section_classes = 'boc-wine-club-section boc-wine-club-benefits boc-wine-club-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-wine-club-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-mobile'
  endunless
-%}

<section
  id="boc-wine-club-benefits-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-wine-club
  style="
    --boc-wc-bg: {{ section.settings.background_color }};
    --boc-wc-text: {{ section.settings.text_color }};
    --boc-wc-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-wc-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-wc-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-wc-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-wc-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-wc-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-wc-heading: {{ section.settings.heading_color }};
    --boc-wc-benefit-divider: {{ section.settings.divider_color }};
    --boc-wc-benefit-heading: {{ section.settings.benefit_heading_color }};
    --boc-wc-benefit-body: {{ section.settings.benefit_body_color }};
  "
>
  <div class="boc-wine-club-section__inner">
    <div class="boc-wine-club-benefits__grid">
      <div class="boc-wine-club-benefits__intro">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow boc-wine-club-section__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-wine-club-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="boc-wine-club-section__body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="boc-wine-club-benefits__list">
          {%- for block in section.blocks -%}
            <div
              class="boc-wine-club-benefits__item"
              style="--boc-wc-benefit-accent: {{ block.settings.accent_color | default: section.settings.accent_color }};"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.number != blank -%}
                <span class="boc-wine-club-benefits__item-number">{{ block.settings.number }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <strong class="boc-wine-club-benefits__item-title">{{ block.settings.heading }}</strong>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="boc-wine-club-benefits__item-body">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Wine Club Benefits",
  "tag": "section",
  "class": "boc-wine-club-benefits-section",
  "max_blocks": 12,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Standard width" },
        { "value": "narrow", "label": "Narrow width" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#212121" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "divider_color", "label": "Divider colour", "default": "#4B4B4B" },
    { "type": "color", "id": "benefit_heading_color", "label": "Benefit heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "benefit_body_color", "label": "Benefit body colour", "default": "#BDBDBD" },
    { "type": "color", "id": "accent_color", "label": "Default accent colour", "default": "#B99E7E" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 100 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 82 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 82 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Member benefits" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More than a delivery." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Membership brings you closer to our vineyards, our winemaking team and the seasonal rhythm of the estate." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Benefit title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "number", "label": "Optional number" },
        { "type": "color", "id": "accent_color", "label": "Accent colour" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Wine Club Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "heading": "Flexible selections", "description": "Choose your wines before every shipment, or let our team curate a seasonal mix." } },
        { "type": "benefit", "settings": { "heading": "Member pricing", "description": "Save between 10% and 30% online and at the cellar door." } },
        { "type": "benefit", "settings": { "heading": "Complimentary tastings", "description": "Enjoy hosted tastings when you visit the estate." } },
        { "type": "benefit", "settings": { "heading": "Priority access", "description": "Be first to discover limited releases, museum wines and member events." } },
        { "type": "benefit", "settings": { "heading": "Easy account management", "description": "Update your wines, delivery details and payment preferences online." } },
        { "type": "benefit", "settings": { "heading": "Member experiences", "description": "Receive invitations to seasonal lunches, release tastings and special events." } }
      ]
    }
  ]
}
{% endschema %}
