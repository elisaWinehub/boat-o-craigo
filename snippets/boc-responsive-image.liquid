{%- doc -%}
  Renders a responsive image with optional mobile source.

  @param {object} image - Primary image object
  @param {object} [mobile_image] - Optional mobile-specific image
  @param {string} [alt] - Alt text override
  @param {string} [class] - CSS class for img element
  @param {string} [loading] - lazy | eager
  @param {string} [sizes] - sizes attribute
  @param {string} [widths] - Comma-separated widths for srcset

  @example
  {% render 'boc-responsive-image',
    image: section.settings.image,
    mobile_image: section.settings.mobile_image,
    alt: section.settings.image.alt,
    loading: 'lazy',
    sizes: '(min-width: 720px) 50vw, 100vw',
    widths: '375, 750, 1100, 1500'
  %}
{%- enddoc -%}

{%- if image != blank -%}
  {%- liquid
    assign img_alt = alt | default: image.alt | escape
    assign img_loading = loading | default: 'lazy'
    assign img_class = class | default: ''
    assign img_widths = widths | default: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
    assign img_sizes = sizes | default: '100vw'
    assign width_values = img_widths | split: ','
  -%}

  {%- if mobile_image != blank -%}
    <picture>
      <source
        media="(max-width: 719px)"
        srcset="
          {%- for w in width_values -%}
            {{ mobile_image | image_url: width: w | strip }} {{ w | strip }}w{%- unless forloop.last -%}, {% endunless -%}
          {%- endfor -%}
        "
        sizes="{{ img_sizes }}"
      >
      {{
        image
        | image_url: width: 1500
        | image_tag:
          class: img_class,
          loading: img_loading,
          alt: img_alt,
          widths: img_widths,
          sizes: img_sizes
      }}
    </picture>
  {%- else -%}
    {{
      image
      | image_url: width: 1500
      | image_tag:
        class: img_class,
        loading: img_loading,
        alt: img_alt,
        widths: img_widths,
        sizes: img_sizes
    }}
  {%- endif -%}
{%- endif -%}
