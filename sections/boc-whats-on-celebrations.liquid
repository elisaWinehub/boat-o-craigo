{%- liquid
  assign section_classes = 'boc-whats-on-section boc-whats-on-celebrations boc-whats-on-section--standard'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-whats-on-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-mobile'
  endunless
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-whats-on-celebrations' }}"
  class="{{ section_classes }}"
  data-boc-whats-on
  style="
    --boc-wo-bg: {{ section.settings.background_color }};
    --boc-wo-text: {{ section.settings.text_color }};
    --boc-wo-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-wo-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-wo-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-wo-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-wo-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-wo-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-wo-heading: {{ section.settings.heading_color }};
    --boc-wo-body: {{ section.settings.body_color }};
  "
>
  <div class="boc-whats-on-section__inner">
    <div class="boc-whats-on-section__head">
      <div class="boc-whats-on-section__head-text">
        {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="boc-whats-on-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.intro_body != blank -%}<p class="boc-whats-on-section__head-aside">{{ section.settings.intro_body }}</p>{%- endif -%}
    </div>
    <div class="boc-whats-on-celebrations__grid">
      {%- for block in section.blocks -%}
        {% render 'boc-feature-card', block: block, variant: 'celebration' %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — WO Celebrations",
  "tag": "section",
  "class": "boc-whats-on-celebrations-section",
  "max_blocks": 4,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-whats-on-celebrations" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#212121" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "body_color", "label": "Body colour", "default": "#BBBBBB" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your occasion, our estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Celebrate among the vines." },
    { "type": "textarea", "id": "intro_body", "label": "Intro", "default": "Whether you are planning a wedding, a milestone or a relaxed gathering, our team will help shape the estate around your occasion." }
  ],
  "blocks": [
    {
      "type": "celebration",
      "name": "Celebration card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Weddings" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Made for your day." },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Plan your wedding" },
        { "type": "text", "id": "button_anchor", "label": "Button anchor", "default": "boc-whats-on-enquiry" },
        { "type": "select", "id": "enquiry_type", "label": "Enquiry tab", "options": [{"value":"wedding","label":"Wedding"},{"value":"private","label":"Private event"}],"default": "wedding" },
        { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" },
        { "type": "range", "id": "card_height", "label": "Card height", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 660 }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — WO Celebrations",
      "blocks": [
        { "type": "celebration", "settings": { "eyebrow": "Weddings", "heading": "Made for your day.", "body": "Contemporary architecture, vineyard views and flexible spaces for ceremonies, receptions and unforgettable photographs.", "button_label": "Plan your wedding", "enquiry_type": "wedding" } },
        { "type": "celebration", "settings": { "eyebrow": "Private events", "heading": "Gather your people.", "body": "Birthdays, corporate lunches, family occasions and milestone celebrations, supported by estate wines and locally focused menus.", "button_label": "Plan a private event", "enquiry_type": "private" } }
      ]
    }
  ]
}
{% endschema %}
