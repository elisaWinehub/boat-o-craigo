{%- liquid
  assign section_classes = 'boc-home-section boc-home-story boc-home-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless

  assign image_url = 'boc-estate-vineyard.jpg' | asset_url
  if section.settings.image != blank
    assign image_url = section.settings.image | image_url: width: 1600
  endif

  assign grid_class = 'boc-home-story__grid'
  if section.settings.image_position == 'right'
    assign grid_class = grid_class | append: ' boc-home-story__grid--image-right'
  endif
-%}

<section
  id="boc-home-story-{{ section.id }}"
  class="{{ section_classes }}"
  style="--boc-section-bg: {{ section.settings.background_color }}; --boc-section-pt: {{ section.settings.padding_top }}px; --boc-section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="boc-home-section__inner">
    <div class="{{ grid_class }}">
      <div class="boc-home-story__media">
        <img
          src="{{ image_url }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          loading="lazy"
          width="1200"
          height="660"
        >
        {%- if section.settings.badge_text != blank -%}
          <div class="boc-home-story__badge">{{ section.settings.badge_text | newline_to_br }}</div>
        {%- endif -%}
      </div>

      <div class="boc-home-story__copy">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-home-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p>{{ section.settings.body }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="boc-home-story__stats">
            {%- for block in section.blocks -%}
              <div class="boc-home-story__stat" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <strong>{{ block.settings.title }}</strong>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span>{{ block.settings.label }}</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="boc-btn boc-btn--light">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Story",
  "tag": "section",
  "class": "boc-home-story-section",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#212121" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wine shaped by place, season and family." },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Boat O'Craigo is a family-owned winery built around two distinctive Yarra Valley vineyard sites. Each wine is made in small parcels to preserve the character of its fruit and the place it comes from."
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "textarea",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Family owned.\nYarra Valley grown."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover our story" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Stat title" },
        { "type": "text", "id": "label", "label": "Label", "default": "Stat label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Story",
      "blocks": [
        { "type": "stat", "settings": { "title": "Family Owned", "label": "Independent since 2000" } },
        { "type": "stat", "settings": { "title": "Single Vineyard", "label": "Site-led winemaking" } },
        { "type": "stat", "settings": { "title": "Cool Climate", "label": "Yarra Valley character" } },
        { "type": "stat", "settings": { "title": "Small Batch", "label": "Handcrafted releases" } }
      ]
    }
  ]
}
{% endschema %}
