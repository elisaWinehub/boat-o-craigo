{%- liquid
  assign section_classes = 'boc-visit-section boc-visit-final-cta boc-visit-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-visit-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-visit-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-visit-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-visit-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-visit.jpg' | asset_url
  assign book_url = section.settings.book_now_url | default: '/pages/book-now'
  assign tasting_url = section.settings.tasting_booking_url | default: book_url
  assign restaurant_url = section.settings.restaurant_booking_url | default: book_url
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-visit-book' }}"
  class="{{ section_classes }}"
  data-boc-visit
  style="
    --boc-v-overlay: {{ section.settings.overlay_color }};
    --boc-v-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-v-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-v-final-min-h-m: {{ section.settings.height_mobile }}px;
    --boc-v-content-width: {{ section.settings.content_width }}px;
  "
>
  <div class="boc-visit-final-cta__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="520">
    {%- endif -%}
  </div>
  <div class="boc-visit-final-cta__overlay" aria-hidden="true"></div>
  <div class="boc-container boc-visit-final-cta__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-visit-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-visit-final-cta__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="{{ section.settings.button_1_url | default: tasting_url }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}"
          {%- if section.settings.button_1_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
        >{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank -%}
        <a href="{{ section.settings.button_2_url | default: restaurant_url }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}"
          {%- if section.settings.button_2_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
        >{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Visit Final CTA",
  "tag": "section",
  "class": "boc-visit-final-cta-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-visit-book" },
    { "type": "url", "id": "book_now_url", "label": "Book Now page URL", "default": "/pages/book-now" },
    { "type": "url", "id": "tasting_booking_url", "label": "Wine tasting booking URL" },
    { "type": "url", "id": "restaurant_booking_url", "label": "Restaurant booking URL" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 50 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 520 },
    { "type": "range", "id": "height_mobile", "label": "Mobile height", "min": 360, "max": 700, "step": 20, "unit": "px", "default": 480 },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 780 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plan your visit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Make a day of it." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Reserve a tasting, book a table in the Glasshouse or speak with our team about a group experience." },
    { "type": "header", "content": "Button 1" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Book a tasting" },
    { "type": "url", "id": "button_1_url", "label": "URL" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "checkbox", "id": "button_1_new_tab", "label": "Open in new tab", "default": false },
    { "type": "header", "content": "Button 2" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Reserve a table" },
    { "type": "url", "id": "button_2_url", "label": "URL" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" },
    { "type": "checkbox", "id": "button_2_new_tab", "label": "Open in new tab", "default": false }
  ],
  "presets": [{ "name": "BOC — Visit Final CTA" }]
}
{% endschema %}
