{%- doc -%}
  Renders an accessible FAQ accordion item.

  @param {object} block - FAQ block with settings
  @param {string} section_id - Parent section ID
  @param {boolean} is_open - Whether item starts open
  @param {string} divider_color - Divider line colour
  @param {string} question_color - Question text colour
  @param {string} answer_color - Answer text colour
  @param {string} icon_color - Plus/minus icon colour
{%- enddoc -%}

{%- liquid
  assign item_id = 'boc-faq-' | append: section_id | append: '-' | append: block.id
  assign open_class = ''
  if is_open
    assign open_class = ' is-open'
  endif
-%}

<div
  class="boc-wine-club-faq__item{{ open_class }}"
  style="--boc-faq-divider: {{ divider_color }}; --boc-faq-question: {{ question_color }}; --boc-faq-answer: {{ answer_color }}; --boc-faq-icon: {{ icon_color }};"
  {{ block.shopify_attributes }}
>
  <h3 class="boc-wine-club-faq__question">
    <button
      type="button"
      class="boc-wine-club-faq__trigger"
      aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
      aria-controls="{{ item_id }}-panel"
      id="{{ item_id }}-trigger"
    >
      <span class="boc-wine-club-faq__question-text">{{ block.settings.question }}</span>
      <span class="boc-wine-club-faq__icon" aria-hidden="true">{% if is_open %}−{% else %}+{% endif %}</span>
    </button>
  </h3>
  <div
    id="{{ item_id }}-panel"
    class="boc-wine-club-faq__panel"
    role="region"
    aria-labelledby="{{ item_id }}-trigger"
    {% unless is_open %}hidden{% endunless %}
  >
    <div class="boc-wine-club-faq__answer rte">
      {{ block.settings.answer }}
    </div>
  </div>
</div>
