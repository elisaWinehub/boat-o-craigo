    "boc_contact_faq": {
      "type": "boc-contact-faq",
      "blocks": {
        "faq_hours": {
          "type": "faq",
          "settings": {
            "category": "Cellar Door & Restaurant",
            "question": "What are your opening hours?",
            "answer": "<p>The Cellar Door is generally open Thursday to Monday from 10am to 5pm, with tastings available until 4pm. Restaurant service times vary between weekdays and weekends.</p>",
            "open_by_default": true
          }
        },
        "faq_tasting_book": {
          "type": "faq",
          "settings": {
            "category": "Cellar Door & Restaurant",
            "question": "Do I need to book a wine tasting?",
            "answer": "<p>Walk-ins may be accepted when space allows, but bookings are recommended—especially on weekends and public holidays.</p>",
            "open_by_default": false
          }
        },
        "faq_dietary": {
          "type": "faq",
          "settings": {
            "category": "Cellar Door & Restaurant",
            "question": "Can you accommodate dietary requirements?",
            "answer": "<p>Most common dietary requirements can be accommodated with notice. Add them during booking or contact the team before your visit.</p>",
            "open_by_default": false
          }
        },
        "faq_wc_update": {
          "type": "faq",
          "settings": {
            "category": "Wine Club & Our Wines",
            "question": "How do I update my Wine Club details?",
            "answer": "<p>Members can update account information through the customer portal or contact the Wine Club team for assistance.</p>",
            "open_by_default": false
          }
        },
        "faq_vegan": {
          "type": "faq",
          "settings": {
            "category": "Wine Club & Our Wines",
            "question": "Do you offer vegan wines?",
            "answer": "<p>Some wines may be suitable for vegan customers. Final production copy should be confirmed against current winemaking and product information.</p>",
            "open_by_default": false
          }
        },
        "faq_storage": {
          "type": "faq",
          "settings": {
            "category": "Wine Club & Our Wines",
            "question": "How should I store my wine?",
            "answer": "<p>Store wine in a cool, dark place with a consistent temperature. Bottles sealed with cork should generally be stored on their side.</p>",
            "open_by_default": false
          }
        },
        "faq_vouchers": {
          "type": "faq",
          "settings": {
            "category": "Orders & Delivery",
            "question": "Can I buy gift vouchers online?",
            "answer": "<p>Yes. Gift vouchers and gift products can be purchased through the online store, subject to the final Shopify catalogue setup.</p>",
            "open_by_default": false
          }
        },
        "faq_delivery": {
          "type": "faq",
          "settings": {
            "category": "Orders & Delivery",
            "question": "How long will delivery take?",
            "answer": "<p>Delivery timing depends on the destination and fulfilment schedule. Order confirmation and tracking information will be sent by email.</p>",
            "open_by_default": false
          }
        },
        "faq_damaged": {
          "type": "faq",
          "settings": {
            "category": "Orders & Delivery",
            "question": "What should I do if my order arrives damaged?",
            "answer": "<p>Photograph the damaged packaging and products, keep the items, and contact the team with your order number so they can assist.</p>",
            "open_by_default": false
          }
        }
      },
