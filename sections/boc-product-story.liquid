{%- liquid
  assign subregion = product.metafields.wine.subregion
  assign region = product.metafields.wine.region
  assign winemaker = product.metafields.wine.winemaker
  assign winemaking = product.metafields.wine.winemaking_notes

  assign story_image = section.settings.image
  assign default_story_image_url = 'https://cdn.shopify.com/s/files/1/0698/9912/4820/files/Wine-10.jpg?v=1784072202'
  assign use_default_story_image = false
  if story_image == blank
    assign use_default_story_image = true
  endif

  assign body = section.settings.body
  if body == blank and winemaking != blank
    assign body = winemaking | metafield_tag | strip_html
  endif

  assign eyebrow = section.settings.eyebrow | default: 'From the vineyard'
  assign heading = section.settings.heading

  assign has_copy = false
  if body != blank or heading != blank or subregion != blank or region != blank or winemaker != blank
    assign has_copy = true
  endif

  assign has_image = false
  if story_image != blank or use_default_story_image
    assign has_image = true
  endif

  assign should_render = false
  if has_image and has_copy
    assign should_render = true
  endif
  if section.settings.force_show
    assign should_render = true
  endif
-%}

{%- if should_render -%}
<section
  class="product-story"
  data-section-type="image-with-text"
  {{ section.shopify_attributes }}
>
  <div class="product-story-media">
    {%- if use_default_story_image -%}
      <img src="{{ default_story_image_url }}" alt="{{ product.title | escape }}" loading="lazy" width="1600" height="680">
    {%- elsif story_image != blank -%}
      {%- if story_image.media_type -%}
        {{ story_image | image_url: width: 1600 | image_tag: alt: product.title, loading: 'lazy', widths: '800, 1200, 1600' }}
      {%- else -%}
        {{ story_image | image_url: width: 1600 | image_tag: alt: story_image.alt | default: product.title, loading: 'lazy', widths: '800, 1200, 1600' }}
      {%- endif -%}
    {%- endif -%}
  </div>
  <div
    class="product-story-copy"
    style="--product-story-copy-bg: {{ section.settings.copy_background_color | default: '#171717' }};"
  >
    {%- if eyebrow != blank -%}
      <span class="eyebrow boc-eyebrow">{{ eyebrow }}</span>
    {%- endif -%}
    {%- if heading != blank -%}
      <h2 class="display boc-display">{{ heading }}</h2>
    {%- endif -%}
    {%- if body != blank -%}
      <p>{{ body }}</p>
    {%- endif -%}
    <ul class="product-story-list">
      {%- if subregion != blank -%}
        <li><span>{{ section.settings.vineyard_label | default: 'Vineyard' }}</span><strong>{{ subregion }}</strong></li>
      {%- endif -%}
      {%- if region != blank -%}
        <li><span>{{ section.settings.region_label | default: 'Region' }}</span><strong>{{ region }}</strong></li>
      {%- endif -%}
      {%- if winemaker != blank -%}
        <li><span>{{ section.settings.winemaker_label | default: 'Winemaking' }}</span><strong>{{ winemaker }}</strong></li>
      {%- endif -%}
    </ul>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "BOC — Product story",
  "tag": "section",
  "class": "boc-product-story-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image override" },
    { "type": "color", "id": "copy_background_color", "label": "Copy panel background", "default": "#171717" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the vineyard" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Cool climate. Bright character." },
    { "type": "textarea", "id": "body", "label": "Body copy", "info": "Defaults to wine.winemaking_notes when blank." },
    { "type": "text", "id": "vineyard_label", "label": "Vineyard label", "default": "Vineyard" },
    { "type": "text", "id": "region_label", "label": "Region label", "default": "Climate" },
    { "type": "text", "id": "winemaker_label", "label": "Winemaker label", "default": "Winemaking" },
    {
      "type": "checkbox",
      "id": "force_show",
      "label": "Always show section (Theme Editor override)",
      "default": false,
      "info": "Enable to preview the section even when product metafields are empty."
    }
  ],
  "presets": [
    { "name": "BOC — Product story" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
