{%- liquid
  assign section_classes = 'boc-home-section boc-home-newsletter boc-home-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless
-%}

<section
  id="boc-home-newsletter-{{ section.id }}"
  class="{{ section_classes }}"
  style="--boc-section-bg: {{ section.settings.background_color }}; --boc-section-pt: {{ section.settings.padding_top }}px; --boc-section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="boc-home-section__inner">
    <div class="boc-home-newsletter__inner">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-home-newsletter__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="boc-home-section__body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>

      {% form 'customer', class: 'boc-home-newsletter__form-wrapper' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="boc-home-newsletter__form">
          <label class="visually-hidden" for="boc-newsletter-email-{{ section.id }}">
            {{ section.settings.input_placeholder | default: 'Your email address' }}
          </label>
          <input
            id="boc-newsletter-email-{{ section.id }}"
            class="boc-home-newsletter__input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ section.settings.input_placeholder | default: 'Your email address' }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
            {% if form.errors %}
              aria-invalid="true"
            {% endif %}
          >
          <button type="submit" class="boc-home-newsletter__submit">
            {{ section.settings.button_label | default: 'Join the list →' }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="boc-home-newsletter__message">{{ section.settings.success_message | default: 'Thanks for subscribing.' }}</p>
        {%- elsif form.errors -%}
          <p class="boc-home-newsletter__message boc-home-newsletter__message--error">
            {{ form.errors.translated_fields.email | default: form.errors.messages.email | first }}
          </p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Newsletter",
  "tag": "section",
  "class": "boc-home-newsletter-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#B99E7E" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 72 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the vineyard" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Be the first to know." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "input_placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the list →" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for subscribing." }
  ],
  "presets": [
    {
      "name": "BOC — Newsletter"
    }
  ]
}
{% endschema %}
