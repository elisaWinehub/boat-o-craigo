          "label": "Link"
        },
        {
          "type": "select",
          "id": "button_1_style",
          "label": "Style",
          "options": [
            { "value": "light", "label": "Light outline" },
            { "value": "accent", "label": "Accent" },
            { "value": "primary", "label": "Primary" },
            { "value": "outline", "label": "Dark outline" }
          ],
