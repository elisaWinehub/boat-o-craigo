{%- liquid
  assign section_classes = 'boc-contact-section boc-contact-faq boc-contact-section--standard'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-contact-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-contact-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-contact-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-contact-section--hide-mobile'
  endunless
  assign one_open = section.settings.one_open_only
  assign first_open = section.settings.first_item_open
  assign category_order = section.settings.category_order | split: '|'
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-contact-faq' }}"
  class="{{ section_classes }}"
  data-boc-contact
  style="
    --boc-ct-faq-bg: {{ section.settings.background_color }};
    --boc-ct-faq-text: {{ section.settings.text_color }};
    --boc-ct-faq-category: {{ section.settings.category_color }};
    --boc-ct-faq-divider: {{ section.settings.divider_color }};
    --boc-ct-faq-question: {{ section.settings.question_color }};
    --boc-ct-faq-answer: {{ section.settings.answer_color }};
    --boc-ct-faq-ratio: {{ section.settings.heading_column_ratio | default: '0.72fr 1.28fr' }};
    --boc-ct-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --boc-ct-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-ct-pad-top-t: {{ section.settings.padding_top_tablet }}px;
    --boc-ct-pad-bottom-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-ct-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --boc-ct-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="boc-contact-section__inner{% if section.settings.container_width == 'narrow' %} boc-contact-section--narrow{% endif %}">
    <div class="boc-contact-faq__layout">
      <div class="boc-contact-faq__intro">
        {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="boc-contact-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div
          class="boc-contact-faq__list"
          data-boc-contact-faq
          data-one-open="{% if one_open %}true{% else %}false{% endif %}"
        >
          {%- for category in category_order -%}
            {%- assign category_name = category | strip -%}
            {%- if category_name == blank -%}{%- continue -%}{%- endif -%}
            {%- assign category_has_items = false -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.category == category_name -%}
                {%- assign category_has_items = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless category_has_items -%}{%- continue -%}{%- endunless -%}

            <div class="boc-contact-faq__category">
              <h3>{{ category_name }}</h3>
              {%- assign category_first = true -%}
              {%- for block in section.blocks -%}
                {%- if block.settings.category != category_name -%}{%- continue -%}{%- endif -%}
                {%- liquid
                  assign open_item = false
                  if block.settings.open_by_default
                    assign open_item = true
                  elsif first_open and category_first
                    assign open_item = true
                  endif
                  assign category_first = false
                -%}
                {% render 'boc-faq-item',
                  block: block,
                  section_id: section.id,
                  is_open: open_item,
                  divider_color: section.settings.divider_color,
                  question_color: section.settings.question_color,
                  answer_color: section.settings.answer_color,
                  icon_color: section.settings.icon_color,
                  namespace: 'contact'
                %}
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Contact FAQ",
  "tag": "section",
  "class": "boc-contact-faq-section",
  "max_blocks": 24,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-contact-faq" },
    { "type": "select", "id": "container_width", "label": "Container width", "options": [{"value":"standard","label":"Standard"},{"value":"narrow","label":"Narrow"}],"default": "standard" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#333333" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "category_color", "label": "Category heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "divider_color", "label": "Divider colour", "default": "#4A4A4A" },
    { "type": "color", "id": "question_color", "label": "Question colour", "default": "#FFFFFF" },
    { "type": "color", "id": "answer_color", "label": "Answer colour", "default": "#BFBFBF" },
    { "type": "color", "id": "icon_color", "label": "Plus/minus colour", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "one_open_only", "label": "Allow one open item only", "default": true },
    { "type": "checkbox", "id": "first_item_open", "label": "First item open by default", "default": true },
    { "type": "text", "id": "heading_column_ratio", "label": "Heading column ratio", "default": "0.72fr 1.28fr" },
    { "type": "text", "id": "category_order", "label": "Category order", "default": "Cellar Door & Restaurant|Wine Club & Our Wines|Orders & Delivery", "info": "Pipe-separated list matching FAQ block categories." },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 40, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 40, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 40, "max": 128, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 40, "max": 128, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 40, "max": 120, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 40, "max": 120, "step": 8, "unit": "px", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently asked questions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Answers before you need to ask." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "select", "id": "category", "label": "Category", "options": [
          {"value":"Cellar Door & Restaurant","label":"Cellar Door & Restaurant"},
          {"value":"Wine Club & Our Wines","label":"Wine Club & Our Wines"},
          {"value":"Orders & Delivery","label":"Orders & Delivery"}
        ], "default": "Cellar Door & Restaurant" },
        { "type": "text", "id": "question", "label": "Question", "default": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer copy.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "BOC — Contact FAQ" }]
}
{% endschema %}
