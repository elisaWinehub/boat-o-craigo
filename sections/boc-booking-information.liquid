{%- liquid
  assign section_classes = 'boc-booking-section boc-booking-info boc-booking-section--standard'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-booking-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-booking-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-booking-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-booking-section--hide-mobile'
  endunless
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-booking-information' }}"
  class="{{ section_classes }}"
  data-boc-booking
  style="
    --boc-bk-bg: {{ section.settings.background_color }};
    --boc-bk-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-bk-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-bk-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-bk-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-bk-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-bk-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-bk-info-cols-d: {{ section.settings.columns_desktop }};
    --boc-bk-info-cols-t: {{ section.settings.columns_tablet }};
  "
>
  <div class="boc-booking-section__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="boc-booking-section__head">
        <div class="boc-booking-section__head-text">
          {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2 class="boc-booking-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="boc-booking-info__grid">
      {%- for block in section.blocks -%}
        {% render 'boc-booking-info-card', block: block %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Booking Info",
  "tag": "section",
  "class": "boc-booking-info-section",
  "max_blocks": 6,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-booking-information" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_tablet", "label": "Tablet columns", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80 },
    { "type": "text", "id": "eyebrow", "label": "Section eyebrow" },
    { "type": "text", "id": "heading", "label": "Section heading" }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Information card",
      "settings": [
        { "type": "select", "id": "card_style", "label": "Card style", "options": [{"value":"light","label":"Light"},{"value":"dark","label":"Dark"},{"value":"accent","label":"Accent"}],"default": "light" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Opening hours" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Plan your arrival." },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "detail_1_label", "label": "Detail 1 label" },
        { "type": "text", "id": "detail_1_value", "label": "Detail 1 value" },
        { "type": "text", "id": "detail_2_label", "label": "Detail 2 label" },
        { "type": "text", "id": "detail_2_value", "label": "Detail 2 value" },
        { "type": "text", "id": "detail_3_label", "label": "Detail 3 label" },
        { "type": "text", "id": "detail_3_value", "label": "Detail 3 value" },
        { "type": "text", "id": "detail_4_label", "label": "Detail 4 label" },
        { "type": "text", "id": "detail_4_value", "label": "Detail 4 value" },
        { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": false },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_url", "label": "Button URL" },
        { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"primary","label":"Primary"},{"value":"light","label":"Light"}],"default": "primary" },
        { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false },
        { "type": "text", "id": "link_label", "label": "Text link label" },
        { "type": "url", "id": "link_url", "label": "Text link URL" },
        { "type": "checkbox", "id": "link_new_tab", "label": "Link opens in new tab", "default": false },
        { "type": "color", "id": "background_color", "label": "Background override" },
        { "type": "color", "id": "text_color", "label": "Text colour override" },
        { "type": "color", "id": "link_color", "label": "Link colour override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Booking Info",
      "blocks": [
        { "type": "info", "settings": { "eyebrow": "Opening hours", "heading": "Plan your arrival.", "detail_1_label": "Cellar Door", "detail_1_value": "10am–5pm", "detail_2_label": "Restaurant", "detail_2_value": "11am–4pm", "detail_3_label": "Recommended arrival", "detail_3_value": "10 minutes early" } },
        { "type": "info", "settings": { "card_style": "dark", "eyebrow": "Group bookings", "heading": "Bringing 11 or more guests?", "body": "Large groups, celebrations and private functions should contact the team directly so the right space and service can be arranged.", "link_label": "Email the team", "link_url": "mailto:info@boatocraigo.com.au" } },
        { "type": "info", "settings": { "eyebrow": "Before visiting", "heading": "Good to know.", "detail_1_label": "Walk-ins", "detail_1_value": "Subject to availability", "detail_2_label": "Dietary needs", "detail_2_value": "Add during booking", "detail_3_label": "Wine tasting", "detail_3_value": "Pre-booking preferred", "detail_4_label": "Children", "detail_4_value": "Include in guest count" } }
      ]
    }
  ]
}
{% endschema %}
