    "boc_booking_faq": {
      "type": "boc-booking-faq",
      "blocks": {
        "faq_tasting_lunch": {
          "type": "faq",
          "settings": {
            "question": "Can I book a wine tasting and lunch together?",
            "answer": "<p>Yes. Select the relevant experience in the live booking system, or make separate reservations where required. Placeholder copy can be replaced once the final booking rules are confirmed.</p>",
            "open_by_default": true
          }
        },
        "faq_large_groups": {
          "type": "faq",
          "settings": {
            "question": "What happens if our group is larger than ten?",
            "answer": "<p>Groups of 11 or more should contact Boat O'Craigo directly. This allows the team to confirm availability, menu format, deposits and seating arrangements.</p>",
            "open_by_default": false
          }
        },
        "faq_dietary": {
          "type": "faq",
          "settings": {
            "question": "Can dietary requirements be accommodated?",
            "answer": "<p>Dietary requirements can be added during booking. The final production content should list any notice periods or limitations provided by the venue.</p>",
            "open_by_default": false
          }
        },
        "faq_children": {
          "type": "faq",
          "settings": {
            "question": "Are children and non-drinkers welcome?",
            "answer": "<p>Yes. All guests should be included in the booking count so the venue can prepare the correct table arrangement and service.</p>",
            "open_by_default": false
          }
        },
        "faq_cancellation": {
          "type": "faq",
          "settings": {
            "question": "What is the cancellation policy?",
            "answer": "<p>Temporary placeholder text. The live page should pull the approved cancellation, no-show and deposit terms from Boat O'Craigo.</p>",
            "open_by_default": false
          }
        }
      },
