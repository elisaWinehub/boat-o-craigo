  ],
  "presets": [
    {
      "name": "BOC — Hero slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Yarra Valley · Victoria",
            "heading": "Wines shaped by place.",
            "body": "Discover cool-climate, single-vineyard wines made at our family-owned Yarra Valley estate.",
            "button_1_label": "Shop wines",
