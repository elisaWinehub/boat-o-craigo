<script src="{{ 'boc-home.js' | asset_url }}" defer></script>

{%- liquid
  assign section_classes = 'boc-home-section boc-home-hero boc-home-section--full boc-home-hero--align-' | append: section.settings.content_alignment
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless
-%}

<section
  id="boc-home-hero-{{ section.id }}"
  class="{{ section_classes }}"
  style="
    --boc-hero-height: {{ section.settings.height_desktop }}vh;
    --boc-hero-min-height: {{ section.settings.min_height_desktop }}px;
    --boc-section-bg: {{ section.settings.background_color }};
  "
  aria-label="{{ section.settings.aria_label | default: 'Featured highlights' | escape }}"
>
  <div
    class="boc-home-hero__slider"
    data-boc-hero-slider
    data-section-id="{{ section.id }}"
    data-autoplay="{{ section.settings.autoplay }}"
    data-autoplay-ms="{{ section.settings.autoplay_speed | times: 1000 }}"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        case forloop.index
          when 1
            assign fallback_asset = 'boc-hero-wines.png'
          when 2
            assign fallback_asset = 'boc-hero-wine-club.png'
          when 4
            assign fallback_asset = 'boc-estate-vineyard.jpg'
          else
            assign fallback_asset = 'boc-estate-visit.jpg'
        endcase

        assign desktop_image = block.settings.image
        assign mobile_image = block.settings.mobile_image
        if desktop_image == blank
          assign desktop_image_url = fallback_asset | asset_url
        else
          assign desktop_image_url = desktop_image | image_url: width: 2400
        endif
        if mobile_image == blank
          if block.settings.image != blank
            assign mobile_image_url = block.settings.image | image_url: width: 1200
          else
            assign mobile_image_url = fallback_asset | asset_url
          endif
        else
          assign mobile_image_url = mobile_image | image_url: width: 1200
        endif
      -%}

      <div
        class="boc-home-hero__slide{% if forloop.first %} is-active{% endif %}"
        data-boc-hero-slide
        aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="boc-home-hero__media">
          <picture>
            <source media="(max-width: 720px)" srcset="{{ mobile_image_url }}">
            <img
              src="{{ desktop_image_url }}"
              alt="{{ block.settings.heading | default: block.settings.eyebrow | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="2400"
              height="1400"
            >
          </picture>
        </div>
        {%- if block.settings.overlay_opacity > 0 -%}
          <div
            class="boc-home-hero__overlay"
            style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
          ></div>
        {%- endif -%}

        <div class="boc-container boc-home-hero__content">
          <div class="boc-home-hero__copy">
            {%- if block.settings.eyebrow != blank -%}
              <span class="boc-eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="boc-home-hero__heading">{{ block.settings.heading }}</h1>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="boc-home-hero__body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.button_1_label != blank or block.settings.button_2_label != blank -%}
              <div class="boc-home-hero__actions">
                {%- if block.settings.button_1_label != blank -%}
                  <a
                    href="{{ block.settings.button_1_link | default: '#' }}"
                    class="boc-btn boc-btn--{{ block.settings.button_1_style }}"
                  >
                    {{ block.settings.button_1_label }}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_2_label != blank -%}
                  <a
                    href="{{ block.settings.button_2_link | default: '#' }}"
                    class="boc-btn boc-btn--{{ block.settings.button_2_style }}"
                  >
                    {{ block.settings.button_2_label }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}

    {%- if section.blocks.size > 1 -%}
      <div class="boc-home-hero__controls">
        {%- if section.settings.show_dots -%}
          <div class="boc-home-hero__dots">
            {%- for block in section.blocks -%}
              <button
                type="button"
                class="boc-home-hero__dot{% if forloop.first %} is-active{% endif %}"
                data-boc-hero-dot
                aria-label="Slide {{ forloop.index }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.show_arrows -%}
          <button type="button" class="boc-home-hero__arrow" data-boc-hero-prev aria-label="Previous slide">
            ←
          </button>
          <button type="button" class="boc-home-hero__arrow" data-boc-hero-next aria-label="Next slide">
            →
          </button>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BOC — Hero slider",
  "tag": "section",
  "class": "boc-home-hero-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "checkbox",
      "id": "section_enabled",
      "label": "Enable section",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_desktop",
      "label": "Show on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tablet",
      "label": "Show on tablet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "full"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#212121"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Hero height"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height (vh)",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 92
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height",
      "min": 400,
      "max": 940,
      "step": 20,
      "unit": "px",
      "default": 700
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay interval",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Featured highlights"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 100
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        },
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
