{%- liquid
  assign section_classes = 'boc-contact-section boc-contact-hero boc-contact-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-contact-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-contact-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-contact-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-contact-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-vineyard.jpg' | asset_url
  assign form_anchor = section.settings.form_anchor | default: 'boc-contact-form'
  assign faq_anchor = section.settings.faq_anchor | default: 'boc-contact-faq'
  assign align_desktop = section.settings.text_alignment_desktop | default: 'left'
-%}

{{ 'boc-contact.css' | asset_url | stylesheet_tag }}
<script src="{{ 'boc-contact.js' | asset_url }}" defer></script>

<section
  id="boc-contact-hero-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-contact
  style="
    {%- render 'boc-page-hero-vars', section: section, prefix: 'ct' -%}
    --boc-hero-heading-mt: {{ section.settings.heading_margin_top | default: 0 }}px;
    --boc-hero-heading-mb: {{ section.settings.heading_margin_bottom | default: 0 }}px;
    --boc-ct-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-ct-focal: {{ section.settings.image_focal_point }};
    --boc-ct-content-width: {{ section.settings.content_width }}px;
  "
>
  <div class="boc-contact-hero__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'eager', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="2400" height="650">
    {%- endif -%}
  </div>
  <div class="boc-contact-hero__overlay" aria-hidden="true"></div>
  <div class="boc-contact-hero__content boc-page-hero-align-{{ align_desktop }}">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h1 class="boc-contact-section__heading">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-contact-hero__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="#{{ form_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}" data-boc-contact-scroll>{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank -%}
        <a href="#{{ faq_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}" data-boc-contact-scroll>{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Contact Hero",
  "tag": "section",
  "class": "boc-contact-hero-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "form_anchor", "label": "Form anchor", "default": "boc-contact-form" },
    { "type": "text", "id": "faq_anchor", "label": "FAQ anchor", "default": "boc-contact-faq" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "hero_height_preset", "label": "Hero height", "options": [{"value":"compact","label":"Compact"},{"value":"standard","label":"Standard"},{"value":"tall","label":"Tall"},{"value":"viewport","label":"Full viewport"}],"default": "standard" },
    { "type": "range", "id": "height_desktop", "label": "Desktop height (custom)", "min": 400, "max": 1000, "step": 20, "unit": "px", "default": 640, "info": "Used when height preset is Standard." },
    { "type": "range", "id": "height_tablet", "label": "Tablet height (custom)", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 620, "info": "Used when height preset is Standard." },
    { "type": "range", "id": "height_mobile", "label": "Mobile height (custom)", "min": 360, "max": 800, "step": 20, "unit": "px", "default": 560, "info": "Used when height preset is Standard." },
    { "type": "select", "id": "image_focal_point", "label": "Image focal point", "options": [{"value":"center","label":"Center"},{"value":"62% center","label":"Mobile crop"}],"default": "center" },
    { "type": "range", "id": "content_width", "label": "Content max width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 760 },
    { "type": "select", "id": "text_alignment_desktop", "label": "Desktop alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}],"default": "left" },
    { "type": "select", "id": "text_alignment_mobile", "label": "Mobile alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}],"default": "left" },
    { "type": "range", "id": "heading_margin_top", "label": "Heading spacing above", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "heading_margin_bottom", "label": "Heading spacing below", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact Boat O'Craigo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How can we help?" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Whether you are planning a visit, asking about an order, joining the Wine Club or organising an event, this page brings the right contact details and answers together in one place." },
    { "type": "header", "content": "Primary button" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Send an enquiry" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "header", "content": "Secondary button" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Browse FAQs" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" }
  ],
  "presets": [{ "name": "BOC — Contact Hero" }]
}
{% endschema %}
