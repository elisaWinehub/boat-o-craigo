{%- liquid
  assign section_classes = 'boc-wine-club-section boc-wine-club-hero boc-wine-club-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-wine-club-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-mobile'
  endunless

  assign image_fallback = 'boc-hero-wine-club.png' | asset_url
  assign anchor = section.settings.scroll_anchor | default: 'boc-wine-club-plans'
  assign heading_size = section.settings.heading_size | default: 'display-lg'
  case heading_size
    when 'display-xl'
      assign heading_size_value = 'var(--boc-display-xl)'
    when 'display-md'
      assign heading_size_value = 'var(--boc-display-md)'
    else
      assign heading_size_value = 'var(--boc-display-lg)'
  endcase

  assign align_desktop = section.settings.text_alignment_desktop | default: 'left'
  assign align_mobile = section.settings.text_alignment_mobile | default: 'left'
  assign hero_actions_align = 'flex-start'
  if align_desktop == 'center'
    assign hero_actions_align = 'center'
  elsif align_desktop == 'right'
    assign hero_actions_align = 'flex-end'
  endif
-%}

{{ 'boc-wine-club.css' | asset_url | stylesheet_tag }}
<script src="{{ 'boc-wine-club.js' | asset_url }}" defer></script>

<section
  id="boc-wine-club-hero-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-wine-club
  style="
    --boc-wc-bg: {{ section.settings.background_color }};
    --boc-wc-pt-d: {{ section.settings.padding_top_desktop }}px;
    --boc-wc-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --boc-wc-pt-t: {{ section.settings.padding_top_tablet }}px;
    --boc-wc-pb-t: {{ section.settings.padding_bottom_tablet }}px;
    --boc-wc-pt-m: {{ section.settings.padding_top_mobile }}px;
    --boc-wc-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --boc-wc-overlay: {{ section.settings.overlay_color }};
    --boc-wc-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {%- render 'boc-page-hero-vars', section: section, prefix: 'wc' -%}
    --boc-hero-heading-mt: {{ section.settings.heading_margin_top | default: 0 }}px;
    --boc-hero-heading-mb: {{ section.settings.heading_margin_bottom | default: 0 }}px;
    --boc-wc-hero-h: var(--boc-wc-hero-min-h);
    --boc-wc-focal: {{ section.settings.image_focal_point }};
    --boc-wc-content-width: {{ section.settings.content_width }}px;
    --boc-wc-align-d: {{ align_desktop }};
    --boc-wc-align-m: {{ align_mobile }};
    --boc-wc-hero-actions-align: {{ hero_actions_align }};
    --boc-wc-heading-size: {{ heading_size_value }};
    --boc-wc-heading: {{ section.settings.heading_color }};
    --boc-wc-eyebrow: {{ section.settings.eyebrow_color }};
    --boc-wc-body: {{ section.settings.body_color }};
    --boc-wc-btn-bg: {{ section.settings.button_bg_color }};
    --boc-wc-btn-text: {{ section.settings.button_text_color }};
    --boc-wc-btn-border: {{ section.settings.button_border_color }};
    --boc-wc-btn-hover-bg: {{ section.settings.button_hover_bg_color }};
    --boc-wc-btn-hover-text: {{ section.settings.button_hover_text_color }};
    --boc-wc-btn-hover-border: {{ section.settings.button_hover_border_color }};
  "
>
  <div class="boc-wine-club-hero__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image',
        image: section.settings.image,
        mobile_image: section.settings.mobile_image,
        alt: section.settings.image.alt | default: section.settings.heading,
        loading: 'eager',
        sizes: '100vw',
        class: 'boc-wine-club-hero__img'
      %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="2400" height="940">
    {%- endif -%}
  </div>
  <div class="boc-wine-club-hero__overlay" aria-hidden="true"></div>

  <div class="boc-container boc-wine-club-hero__content boc-wine-club-section__inner boc-page-hero-align-{{ align_desktop }}">
    <div class="boc-wine-club-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="boc-eyebrow boc-wine-club-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="boc-wine-club-section__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="boc-wine-club-section__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
        <div class="boc-wine-club-hero__actions">
          <a
            href="#{{ anchor }}"
            class="boc-btn boc-btn--{{ section.settings.button_style }} boc-wine-club-btn--custom"
            data-boc-wine-club-scroll
            {% if section.settings.button_new_tab %}
              target="_blank"
              rel="noopener noreferrer"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Wine Club Hero",
  "tag": "section",
  "class": "boc-wine-club-hero-section",
  "settings": [
    { "type": "header", "content": "Visibility" },
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "container", "label": "Standard width" },
        { "value": "narrow", "label": "Narrow width" }
      ],
      "default": "full"
    },
    { "type": "color", "id": "background_color", "label": "Background colour fallback", "default": "#333333" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top_tablet", "label": "Tablet padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Tablet padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 0 },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 55 },
    { "type": "select", "id": "hero_height_preset", "label": "Hero height", "options": [{"value":"compact","label":"Compact"},{"value":"standard","label":"Standard"},{"value":"tall","label":"Tall"},{"value":"viewport","label":"Full viewport"}],"default": "standard" },
    { "type": "range", "id": "height_desktop", "label": "Desktop height (custom)", "min": 400, "max": 1000, "step": 20, "unit": "px", "default": 760, "info": "Used when height preset is Standard." },
    { "type": "range", "id": "height_tablet", "label": "Tablet height (custom)", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 700, "info": "Used when height preset is Standard." },
    { "type": "range", "id": "height_mobile", "label": "Mobile height (custom)", "min": 360, "max": 800, "step": 20, "unit": "px", "default": 640, "info": "Used when height preset is Standard." },
    {
      "type": "select",
      "id": "image_focal_point",
      "label": "Image focal point",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "62% center", "label": "Mobile crop (62% center)" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "content_width", "label": "Content max width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 760 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Boat O'Craigo Wine Club" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A wine club designed around you." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Select the membership that suits your cellar, customise every delivery and enjoy member pricing, complimentary tastings and early access to limited releases." },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "display-xl", "label": "Extra large" },
        { "value": "display-lg", "label": "Large" },
        { "value": "display-md", "label": "Medium" }
      ],
      "default": "display-lg"
    },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow colour", "default": "#FFFFFF" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "body_color", "label": "Body colour", "default": "#FFFFFF" },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Desktop alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Mobile alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "range", "id": "heading_margin_top", "label": "Heading spacing above", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "heading_margin_bottom", "label": "Heading spacing below", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "header", "content": "Button" },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View memberships" },
    { "type": "text", "id": "scroll_anchor", "label": "Scroll anchor ID", "default": "boc-wine-club-plans", "info": "Membership plans section anchor" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "accent", "label": "Accent" },
        { "value": "primary", "label": "Primary" },
        { "value": "light", "label": "Light outline" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "accent"
    },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false },
    { "type": "color", "id": "button_bg_color", "label": "Button background", "default": "#B99E7E" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_border_color", "label": "Button border", "default": "#B99E7E" },
    { "type": "color", "id": "button_hover_bg_color", "label": "Hover background", "default": "#212121" },
    { "type": "color", "id": "button_hover_text_color", "label": "Hover text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_hover_border_color", "label": "Hover border", "default": "#212121" }
  ],
  "presets": [{ "name": "BOC — Wine Club Hero" }]
}
{% endschema %}
