{%- liquid
  assign product = closest.product | default: product
  assign source = block.settings.source | default: 'description'
  assign copy = ''

  case source
    when 'description'
      assign copy = product.description | strip_html | strip
    when 'custom'
      assign copy = block.settings.custom_text
  endcase
-%}

{%- if copy != blank -%}
  <div class="product-short-copy-wrap" data-boc-short-copy {{ block.shopify_attributes }}>
    <p class="product-short-copy product-short-copy--clamped" data-boc-short-copy-text>{{ copy }}</p>
    <button
      class="product-short-copy-toggle"
      data-boc-short-copy-toggle
      aria-expanded="false"
      type="button"
    >Read more</button>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "BOC — Short description",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "source",
      "label": "Copy source",
      "options": [
        { "value": "description", "label": "Product description" },
        { "value": "custom", "label": "Custom text (per template)" }
      ],
      "default": "description"
    },
    {
      "type": "textarea",
      "id": "custom_text",
      "label": "Custom text",
      "visible_if": "{{ block.settings.source == 'custom' }}"
    }
  ],
  "presets": [
    {
      "name": "BOC — Short description",
      "category": "Product"
    }
  ]
}
{% endschema %}
