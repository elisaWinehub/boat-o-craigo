{%- liquid
  assign section_classes = 'boc-contact-section boc-contact-location boc-contact-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-contact-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-contact-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-contact-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-contact-section--hide-mobile'
  endunless

  if section.settings.image_side == 'right'
    assign section_classes = section_classes | append: ' boc-contact-location--reverse'
  endif
  if section.settings.mobile_stack_order == 'copy_first'
    assign section_classes = section_classes | append: ' boc-contact-location--mobile-copy-first'
  endif

  assign image_fallback = 'boc-estate-visit.jpg' | asset_url
  assign maps_url = section.settings.google_maps_url | default: settings.boc_google_maps_url
  if maps_url == blank
    assign maps_url = 'https://www.google.com/maps/search/?api=1&query=458+Maroondah+Highway,+Healesville+VIC+3777'
  endif
-%}

<section
  id="{{ section.settings.section_anchor_id | default: 'boc-contact-location' }}"
  class="{{ section_classes }}"
  data-boc-contact
  style="
    --boc-ct-loc-ratio: {{ section.settings.split_ratio | default: '1.05fr 0.95fr' }};
    --boc-ct-loc-min-h: {{ section.settings.desktop_image_height }}px;
    --boc-ct-loc-media-h: {{ section.settings.desktop_image_height }}px;
    --boc-ct-loc-media-h-t: {{ section.settings.tablet_image_height }}px;
    --boc-ct-loc-bg: {{ section.settings.copy_background_color }};
    --boc-ct-loc-text: {{ section.settings.text_color }};
    --boc-ct-loc-media-bg: {{ section.settings.media_background_color }};
  "
>
  <div class="boc-contact-location__media" aria-hidden="true">
    {%- if section.settings.image != blank or section.settings.mobile_image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '(min-width: 981px) 55vw, 100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1600" height="620">
    {%- endif -%}
  </div>

  <div class="boc-contact-location__copy">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-contact-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="boc-contact-location__list">
        {%- for block in section.blocks -%}
          {%- if block.settings.label != blank or block.settings.value != blank -%}
            <li {{ block.shopify_attributes }}>
              {%- if block.settings.label != blank -%}<span>{{ block.settings.label }}</span>{%- endif -%}
              {%- if block.settings.value != blank -%}<strong>{{ block.settings.value }}</strong>{%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
      <a href="{{ maps_url }}" class="boc-btn boc-btn--light"
        {%- if section.settings.button_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
      >{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BOC — Contact Location",
  "tag": "section",
  "class": "boc-contact-location-section",
  "max_blocks": 8,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-contact-location" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "select", "id": "image_side", "label": "Image side", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}],"default": "left" },
    { "type": "select", "id": "mobile_stack_order", "label": "Mobile stack order", "options": [{"value":"image_first","label":"Image first"},{"value":"copy_first","label":"Copy first"}],"default": "image_first" },
    { "type": "text", "id": "split_ratio", "label": "Split ratio", "default": "1.05fr 0.95fr" },
    { "type": "range", "id": "desktop_image_height", "label": "Desktop image height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 620 },
    { "type": "range", "id": "tablet_image_height", "label": "Tablet image height", "min": 320, "max": 720, "step": 20, "unit": "px", "default": 480 },
    { "type": "color", "id": "copy_background_color", "label": "Copy background", "default": "#B99E7E" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "media_background_color", "label": "Media fallback background", "default": "#DCC6A2" },
    { "type": "url", "id": "google_maps_url", "label": "Google Maps URL", "info": "Falls back to theme setting if blank." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Getting here" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find us in Healesville." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Boat O'Craigo is a short drive from central Healesville, at the foot of the Black Spur ranges." },
    { "type": "header", "content": "Directions button" },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get directions" },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": true }
  ],
  "blocks": [
    {
      "type": "detail_row",
      "name": "Detail row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Label" },
        { "type": "text", "id": "value", "label": "Value", "default": "Value" }
      ]
    }
  ],
  "presets": [{ "name": "BOC — Contact Location" }]
}
{% endschema %}
