{%- liquid
  assign section_classes = 'boc-home-section boc-home-journal boc-home-section--' | append: section.settings.container_width | append: ' boc-home-section--align-' | append: section.settings.content_alignment
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless

  assign news_blog = section.settings.blog
  if news_blog == blank
    assign news_blog = blogs.news
  endif

  assign has_blog = false
  if news_blog != blank and news_blog.articles_count > 0
    assign has_blog = true
  endif
-%}

<section
  id="boc-home-journal-{{ section.id }}"
  class="{{ section_classes }}"
  style="--boc-section-bg: {{ section.settings.background_color }}; --boc-section-pt: {{ section.settings.padding_top }}px; --boc-section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="boc-home-section__inner">
    <div class="boc-home-section__head">
      <div class="boc-home-section__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-home-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="boc-home-section__body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: news_blog.url | default: '/blogs/news' }}" class="boc-home-text-link">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="boc-home-cards__grid boc-home-journal__grid">
      {%- if has_blog -%}
        {%- for article in news_blog.articles limit: section.settings.article_limit -%}
          {%- liquid
            assign card_meta = ''
            for tag in article.tags
              unless tag == 'news'
                if card_meta != ''
                  assign card_meta = card_meta | append: ' · '
                endif
                assign card_meta = card_meta | append: tag
              endunless
            endfor

            assign article_date = article.published_at
            if article_date != blank
              assign day_num = article_date | date: '%-d'
              assign month_label = article_date | date: '%b'
            endif
          -%}
          <article class="boc-home-card">
            <a href="{{ article.url }}" class="boc-home-card__media" aria-label="{{ article.title | escape }}">
              {%- if article.image != blank -%}
                <img
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="900"
                  height="320"
                >
              {%- else -%}
                <img
                  src="{{ 'boc-estate-vineyard.jpg' | asset_url }}"
                  alt="{{ article.title | escape }}"
                  loading="lazy"
                  width="900"
                  height="320"
                >
              {%- endif -%}
              {%- if article_date != blank -%}
                <div class="boc-home-card__date">
                  <strong>{{ day_num }}</strong>
                  <span>{{ month_label }}</span>
                </div>
              {%- endif -%}
            </a>
            <div class="boc-home-card__body">
              {%- if card_meta != blank -%}
                <span class="boc-home-card__meta">{{ card_meta }}</span>
              {%- elsif article.blog.title != blank -%}
                <span class="boc-home-card__meta">{{ article.blog.title }}</span>
              {%- endif -%}
              <h3 class="boc-home-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              {%- assign card_excerpt = article.excerpt | default: article.content -%}
              {%- if card_excerpt != blank -%}
                <p class="boc-home-card__excerpt">{{ card_excerpt | strip_html | truncate: 120 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="boc-home-text-link">{{ section.settings.card_link_label | default: 'Read story' }}</a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <article class="boc-home-card">
            <div class="boc-home-card__media">
              <img src="{{ 'boc-estate-vineyard.jpg' | asset_url }}" alt="Journal placeholder" loading="lazy" width="900" height="320">
            </div>
            <div class="boc-home-card__body">
              <span class="boc-home-card__meta">Journal</span>
              <h3 class="boc-home-card__title">Connect the News blog to show articles</h3>
              <p class="boc-home-card__excerpt">Select the News blog in the section settings to populate this grid dynamically.</p>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — News blog",
  "tag": "section",
  "class": "boc-home-journal-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FFFFFF" },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stories from the valley." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Read all stories" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "article_limit", "label": "Articles to show", "min": 1, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "card_link_label", "label": "Card link label", "default": "Read story" }
  ],
  "presets": [
    {
      "name": "BOC — News blog"
    }
  ]
}
{% endschema %}
