{%- liquid
  assign section_classes = 'boc-home-section boc-home-experiences boc-home-section--' | append: section.settings.container_width | append: ' boc-home-section--align-' | append: section.settings.content_alignment
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless
-%}

<section
  id="boc-home-experiences-{{ section.id }}"
  class="{{ section_classes }}"
  style="--boc-section-bg: {{ section.settings.background_color }}; --boc-section-pt: {{ section.settings.padding_top }}px; --boc-section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="boc-home-section__inner">
    <div class="boc-home-section__head">
      <div class="boc-home-section__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-home-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.body != blank -%}
        <p class="boc-home-section__head-aside">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="boc-home-experiences__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign fallback_asset = 'boc-estate-visit.jpg'
          if forloop.index == 2
            assign fallback_asset = 'boc-estate-vineyard.jpg'
          endif
          if block.settings.image != blank
            assign card_image = block.settings.image | image_url: width: 1600
            assign card_alt = block.settings.image.alt | default: block.settings.heading
          else
            assign card_image = fallback_asset | asset_url
            assign card_alt = block.settings.heading
          endif
        -%}
        <a href="{{ block.settings.link | default: '#' }}" class="boc-home-experiences__card" {{ block.shopify_attributes }}>
          <img src="{{ card_image }}" alt="{{ card_alt | escape }}" loading="lazy" width="1200" height="600">
          <div class="boc-home-experiences__copy">
            {%- if block.settings.eyebrow != blank -%}
              <span class="boc-eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3>{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p>{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.link_label != blank -%}
              <span class="boc-home-text-link">{{ block.settings.link_label }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Experiences",
  "tag": "section",
  "class": "boc-home-experiences-section",
  "max_blocks": 4,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FFFFFF" },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visit the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Come for the wine. Stay for the moment." },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Cellar door tastings and seasonal dining, set among the vines in Healesville."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Experience card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Card heading" },
        { "type": "textarea", "id": "body", "label": "Body" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Experiences",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "eyebrow": "Cellar Door",
            "heading": "Book a tasting",
            "body": "Explore our current releases and vineyard stories with a guided tasting.",
            "link_label": "Plan your visit",
            "link": "/pages/visit"
          }
        },
        {
          "type": "feature",
          "settings": {
            "eyebrow": "Glasshouse Restaurant",
            "heading": "Seasonal dining",
            "body": "Relaxed food, estate wines and sweeping views across the vineyard.",
            "link_label": "View the menu",
            "link": "/pages/visit"
          }
        }
      ]
    }
  ]
}
{% endschema %}
