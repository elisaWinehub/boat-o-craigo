{%- liquid
  assign section_classes = 'boc-about-section boc-about-final boc-about-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-about-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-about-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-about-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-about-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-visit.jpg' | asset_url
  assign visit_url = section.settings.button_1_url | default: '/pages/visit'
  assign shop_url = section.settings.button_2_url | default: '/collections/wines'
-%}

<section
  id="boc-about-final-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-about
  style="
    --boc-ab-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-ab-final-width: {{ section.settings.content_width }}px;
    --boc-ab-final-overlay: {{ section.settings.overlay_color }};
    --boc-ab-final-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  <div class="boc-about-final__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="520">
    {%- endif -%}
  </div>
  <div class="boc-about-final__overlay" aria-hidden="true"></div>
  <div class="boc-about-final__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-about-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-about-final__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="{{ visit_url }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}"
          {%- if section.settings.button_1_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
        >{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank -%}
        <a href="{{ shop_url }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}"
          {%- if section.settings.button_2_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
        >{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — About Final CTA",
  "tag": "section",
  "class": "boc-about-final-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 55 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 520 },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 780 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experience the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Come and meet us in the Yarra Valley." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The best way to understand Boat O'Craigo is to taste the wines, see the vineyards and spend some time at the estate." },
    { "type": "header", "content": "Button 1" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Plan your visit" },
    { "type": "url", "id": "button_1_url", "label": "URL" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "checkbox", "id": "button_1_new_tab", "label": "Open in new tab", "default": false },
    { "type": "header", "content": "Button 2" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Shop our wines" },
    { "type": "url", "id": "button_2_url", "label": "URL" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" },
    { "type": "checkbox", "id": "button_2_new_tab", "label": "Open in new tab", "default": false }
  ],
  "presets": [{ "name": "BOC — About Final CTA" }]
}
{% endschema %}
