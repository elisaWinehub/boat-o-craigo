{%- liquid
  assign section_classes = 'boc-whats-on-section boc-whats-on-final-cta boc-whats-on-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-whats-on-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-whats-on-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-visit.jpg' | asset_url
-%}

<section
  id="boc-whats-on-final-cta-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-whats-on
  style="
    --boc-wo-overlay: {{ section.settings.overlay_color }};
    --boc-wo-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-wo-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-wo-final-min-h-m: {{ section.settings.height_mobile }}px;
    --boc-wo-content-width: {{ section.settings.content_width }}px;
  "
>
  <div class="boc-whats-on-final-cta__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="570">
    {%- endif -%}
  </div>
  <div class="boc-whats-on-final-cta__overlay" aria-hidden="true"></div>
  <div class="boc-container boc-whats-on-final-cta__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-whats-on-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
      <a href="#{{ section.settings.button_anchor | default: 'boc-whats-on-enquiry' }}" class="boc-btn boc-btn--{{ section.settings.button_style }}" data-boc-whats-on-scroll>{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BOC — WO Final CTA",
  "tag": "section",
  "class": "boc-whats-on-final-cta-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 50 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 560 },
    { "type": "range", "id": "height_mobile", "label": "Mobile height", "min": 360, "max": 700, "step": 20, "unit": "px", "default": 560 },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 760 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your event at Boat O'Craigo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Let the vineyard set the scene." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Share a few details with our events team and begin planning a celebration that feels entirely your own." },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Make an enquiry" },
    { "type": "text", "id": "button_anchor", "label": "Button anchor", "default": "boc-whats-on-enquiry" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" }
  ],
  "presets": [{ "name": "BOC — WO Final CTA" }]
}
{% endschema %}
