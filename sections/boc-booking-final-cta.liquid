{%- liquid
  assign section_classes = 'boc-booking-section boc-booking-final boc-booking-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-booking-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-booking-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-booking-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-booking-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-hero-wines.png' | asset_url
  assign widget_anchor = section.settings.widget_anchor | default: 'boc-booking-widget'
  assign contact_url = section.settings.button_1_url
  if contact_url == blank
    assign contact_url = '/pages/contact'
  endif
-%}

<section
  id="boc-booking-final-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-booking
  style="
    --boc-bk-overlay: {{ section.settings.overlay_color }};
    --boc-bk-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-bk-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-bk-content-width: {{ section.settings.content_width }}px;
  "
>
  <div class="boc-booking-final__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'lazy', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="500">
    {%- endif -%}
  </div>
  <div class="boc-booking-final__overlay" aria-hidden="true"></div>
  <div class="boc-container boc-booking-final__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="boc-booking-section__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-booking-final__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="{{ contact_url }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}"
          {%- if section.settings.button_1_new_tab -%} target="_blank" rel="noopener noreferrer"{%- endif -%}
        >{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank -%}
        <a href="#{{ widget_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}" data-boc-booking-scroll>{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Booking Final CTA",
  "tag": "section",
  "class": "boc-booking-final-cta-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "widget_anchor", "label": "Booking widget anchor", "default": "boc-booking-widget" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 50 },
    { "type": "range", "id": "height_desktop", "label": "Section height", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 500 },
    { "type": "range", "id": "content_width", "label": "Content width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 780 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Need help?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Not sure which experience to book?" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The cellar door and restaurant team can help with larger groups, accessibility questions, dietary needs and special occasions." },
    { "type": "header", "content": "Primary button" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Contact the team" },
    { "type": "url", "id": "button_1_url", "label": "URL" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "checkbox", "id": "button_1_new_tab", "label": "Open in new tab", "default": false },
    { "type": "header", "content": "Secondary button" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Return to bookings" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" }
  ],
  "presets": [{ "name": "BOC — Booking Final CTA" }]
}
{% endschema %}
