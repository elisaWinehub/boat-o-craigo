{%- liquid
  assign section_classes = 'boc-visit-section boc-visit-glasshouse boc-visit-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-visit-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-visit-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-visit-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-visit-section--hide-mobile'
  endunless
-%}

<section
  id="boc-visit-glasshouse-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-visit
>
  {% render 'boc-feature-split',
    section: section,
    anchor_id: section.settings.section_anchor_id | default: 'boc-visit-glasshouse',
    reverse: true,
    dark_copy: true,
    image_fallback: 'boc-estate-visit.jpg'
  %}
</section>

{% schema %}
{
  "name": "BOC — Visit Glasshouse",
  "tag": "section",
  "class": "boc-visit-glasshouse-section",
  "max_blocks": 8,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-visit-glasshouse" },
    { "type": "url", "id": "booking_url", "label": "Restaurant booking URL", "default": "/pages/book-now" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "split_ratio_reverse", "label": "Split ratio", "default": "0.95fr 1.05fr" },
    { "type": "range", "id": "desktop_image_height", "label": "Desktop image height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 680 },
    { "type": "range", "id": "tablet_image_height", "label": "Tablet image height", "min": 300, "max": 700, "step": 20, "unit": "px", "default": 520 },
    { "type": "range", "id": "mobile_image_height", "label": "Mobile image height", "min": 280, "max": 600, "step": 20, "unit": "px", "default": 380 },
    { "type": "select", "id": "mobile_stack_order", "label": "Mobile stack order", "options": [{"value":"image_first","label":"Image first"},{"value":"copy_first","label":"Copy first"}],"default": "image_first" },
    { "type": "color", "id": "copy_background_color", "label": "Copy background", "default": "#333333" },
    { "type": "color", "id": "copy_text_color", "label": "Copy text", "default": "#FFFFFF" },
    { "type": "color", "id": "copy_body_color", "label": "Body text", "default": "#CCCCCC" },
    { "type": "color", "id": "detail_border_color", "label": "Detail border", "default": "#444444" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Glasshouse" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Come for the view. Stay for the food." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Our relaxed restaurant pairs estate wines with generous, seasonal dishes. Expect artisan cheeses, charcuterie, pizza and locally sourced produce served in a light-filled room overlooking the vineyard." },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Reserve a table" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"light","label":"Light"},{"value":"primary","label":"Primary"}],"default": "light" },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Detail" },
        { "type": "text", "id": "value", "label": "Value", "default": "Value" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Visit Glasshouse",
      "blocks": [
        { "type": "detail", "settings": { "label": "Dining style", "value": "Relaxed à la carte" } },
        { "type": "detail", "settings": { "label": "Group bookings", "value": "Available for 11+" } },
        { "type": "detail", "settings": { "label": "Dietary needs", "value": "Ask our team" } },
        { "type": "detail", "settings": { "label": "Reservations", "value": "Recommended" } }
      ]
    }
  ]
}
{% endschema %}
