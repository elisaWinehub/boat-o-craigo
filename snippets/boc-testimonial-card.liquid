{%- doc -%}
  Renders a testimonial card.

  @param {object} block - Testimonial block
  @param {object} settings - Section settings
{%- enddoc -%}

<article class="boc-whats-on-testimonials__card" {{ block.shopify_attributes }}>
  {%- if settings.show_stars and block.settings.rating > 0 -%}
    <div class="boc-whats-on-testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
      {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
    </div>
  {%- endif -%}
  {%- if block.settings.quote != blank -%}
    <blockquote class="boc-whats-on-testimonials__quote">{{ block.settings.quote }}</blockquote>
  {%- endif -%}
  <cite class="boc-whats-on-testimonials__cite">
    {%- if block.settings.name != blank -%}{{ block.settings.name }}{%- endif -%}
    {%- if block.settings.context != blank -%} · {{ block.settings.context }}{%- endif -%}
  </cite>
</article>
