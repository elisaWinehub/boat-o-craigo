{%- doc -%}
  Vineyard card for About vineyards section.

  @param {object} block - Vineyard block
  @param {string} [image_fallback] - Fallback asset filename
{%- enddoc -%}

{%- liquid
  assign fallback_url = image_fallback | default: 'boc-estate-vineyard.jpg' | asset_url
  assign card_style = ''
  if block.settings.card_background_color != blank
    assign card_style = card_style | append: '--boc-ab-vine-bg: ' | append: block.settings.card_background_color | append: ';'
  endif
  if block.settings.text_color != blank
    assign card_style = card_style | append: '--boc-ab-vine-text: ' | append: block.settings.text_color | append: ';'
  endif
-%}

<article class="boc-about-vineyard" style="{{ card_style }}" {{ block.shopify_attributes }}>
  <div class="boc-about-vineyard__media">
    {%- if block.settings.image != blank or block.settings.mobile_image != blank -%}
      {% render 'boc-responsive-image',
        image: block.settings.image,
        mobile_image: block.settings.mobile_image,
        alt: block.settings.image.alt | default: block.settings.heading,
        loading: 'lazy',
        sizes: '(min-width: 640px) 50vw, 100vw'
      %}
    {%- else -%}
      <img src="{{ fallback_url }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1200" height="570">
    {%- endif -%}
  </div>
  <div class="boc-about-vineyard__copy">
    {%- if block.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ block.settings.eyebrow }}</span>{%- endif -%}
    {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
    {%- if block.settings.body != blank -%}<div class="rte">{{ block.settings.body }}</div>{%- endif -%}
    {%- if block.settings.location_url != blank -%}
      <p style="margin-top:16px;"><a href="{{ block.settings.location_url }}" class="boc-home-text-link">View location</a></p>
    {%- endif -%}
  </div>
</article>
