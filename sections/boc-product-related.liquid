{%- liquid
  assign max_products = section.settings.max_products | default: 4

  assign wines_collection = section.settings.wines_collection
  if wines_collection == blank
    assign wines_collection = collections['wines']
  endif
  if wines_collection == blank
    assign wines_collection = collections.first
  endif
  assign wines_url = wines_collection.url | default: routes.all_products_collection_url
-%}

<section
  class="product-related boc-product-related"
  {{ section.shopify_attributes }}
>
  <div class="boc-container">

    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="display boc-display">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a class="text-link" href="{{ wines_url }}">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>

    {%- comment -%}
      Step 1: siblings from the product's own collections (deduped by id).
      Step 2: fill remaining slots from wines_collection.
      Rendered immediately — no JS, no async, nothing can hide these cards.
    {%- endcomment -%}

    {%- assign found_ids = '' -%}

    {%- capture related_cards -%}
      {%- assign card_count = 0 -%}

      {%- for col in product.collections -%}
        {%- if card_count >= max_products -%}{%- break -%}{%- endif -%}
        {%- for col_product in col.products -%}
          {%- if card_count >= max_products -%}{%- break -%}{%- endif -%}
          {%- if col_product.id == product.id -%}{%- continue -%}{%- endif -%}
          {%- assign id_str = col_product.id | append: ',' -%}
          {%- if found_ids contains id_str -%}{%- continue -%}{%- endif -%}
          {%- assign found_ids = found_ids | append: id_str -%}
          {% render 'boc-related-product-card', product: col_product, section: section %}
          {%- assign card_count = card_count | plus: 1 -%}
        {%- endfor -%}
      {%- endfor -%}

      {%- if card_count < max_products and wines_collection != blank -%}
        {%- for col_product in wines_collection.products -%}
          {%- if card_count >= max_products -%}{%- break -%}{%- endif -%}
          {%- if col_product.id == product.id -%}{%- continue -%}{%- endif -%}
          {%- assign id_str = col_product.id | append: ',' -%}
          {%- if found_ids contains id_str -%}{%- continue -%}{%- endif -%}
          {%- assign found_ids = found_ids | append: id_str -%}
          {% render 'boc-related-product-card', product: col_product, section: section %}
          {%- assign card_count = card_count | plus: 1 -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}

    {%- if related_cards != blank -%}
      <div class="related-grid">{{ related_cards }}</div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "BOC — Related products",
  "tag": null,
  "class": "boc-product-related-section",
  "settings": [
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "collection",
      "id": "wines_collection",
      "label": "Wines collection (fallback source)",
      "info": "Used when a product belongs to no collections, or to fill remaining slots. Set this to your main Wines collection."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "You may also enjoy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related wines."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "View all label",
      "default": "View all wines"
    }
  ],
  "presets": [
    { "name": "BOC — Related products" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
