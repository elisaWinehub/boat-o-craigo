{%- liquid
  assign section_classes = 'boc-home-section boc-home-featured-wines boc-home-section--' | append: section.settings.container_width
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-home-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-home-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-home-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-home-section--hide-mobile'
  endunless

  assign use_collection = false
  if section.settings.source == 'collection' and section.settings.collection != blank
    assign use_collection = true
  endif
-%}

<section
  id="boc-home-featured-wines-{{ section.id }}"
  class="{{ section_classes }}"
  style="
    --boc-section-bg: {{ section.settings.background_color }};
    --boc-section-pt: {{ section.settings.padding_top }}px;
    --boc-section-pb: {{ section.settings.padding_bottom }}px;
    --boc-wine-columns: {{ section.settings.columns }};
  "
>
  <div class="boc-home-section__inner">
    <div class="boc-home-section__head">
      <div class="boc-home-section__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="boc-home-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="boc-home-section__body">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: section.settings.collection.url | default: 'shopify://collections/all' }}" class="boc-home-text-link">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="boc-home-featured-wines__grid">
      {%- if use_collection -%}
        {%- for product in section.settings.collection.products limit: section.settings.product_limit -%}
          {% render 'boc-product-card',
            product: product,
            section: section,
            show_vendor: section.settings.show_vendor,
            show_price: section.settings.show_price,
            show_quantity: section.settings.show_quantity,
            show_add_to_cart: section.settings.show_add_to_cart
          %}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          <div {{ block.shopify_attributes }}>
            {% render 'boc-product-card',
              product: product,
              show_vendor: section.settings.show_vendor,
              show_price: section.settings.show_price,
              show_quantity: section.settings.show_quantity,
              show_add_to_cart: section.settings.show_add_to_cart
            %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Featured wines",
  "tag": "section",
  "class": "boc-home-featured-wines-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "container"
    },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "default": 120 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From our cellar" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore the range." },
    { "type": "textarea", "id": "body", "label": "Body" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop all wines" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    {
      "type": "select",
      "id": "source",
      "label": "Product source",
      "options": [
        { "value": "collection", "label": "Collection" },
        { "value": "manual", "label": "Manual products" }
      ],
      "default": "manual"
    },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "checkbox", "id": "show_quantity", "label": "Show quantity", "default": true },
    { "type": "checkbox", "id": "show_add_to_cart", "label": "Show add to cart", "default": true }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Featured wines",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
