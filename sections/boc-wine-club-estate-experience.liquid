{%- liquid
  assign section_classes = 'boc-wine-club-section boc-wine-club-estate boc-wine-club-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-wine-club-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-mobile'
  endunless

  assign grid_class = 'boc-wine-club-estate__grid'
  if section.settings.image_side == 'right'
    assign grid_class = grid_class | append: ' boc-wine-club-estate__grid--image-right'
  endif
  if section.settings.mobile_stack_order == 'copy_first'
    assign grid_class = grid_class | append: ' boc-wine-club-estate__grid--mobile-copy-first'
  endif

  assign image_url = 'boc-estate-visit.jpg' | asset_url
  if section.settings.image != blank
    assign image_url = section.settings.image | image_url: width: 1800
  endif

  assign split_ratio = section.settings.split_ratio | default: '1.08fr 0.92fr'
-%}

<section
  id="boc-wine-club-estate-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-wine-club
  style="
    --boc-wc-bg: {{ section.settings.background_color }};
    --boc-wc-text: {{ section.settings.text_color }};
    --boc-wc-estate-ratio: {{ split_ratio }};
    --boc-wc-estate-min-h: {{ section.settings.desktop_image_height }}px;
    --boc-wc-estate-media-h: {{ section.settings.desktop_image_height }}px;
    --boc-wc-heading: {{ section.settings.heading_color }};
  "
>
  <div class="{{ grid_class }}">
    <div class="boc-wine-club-estate__media">
      {%- if section.settings.image != blank or section.settings.mobile_image != blank -%}
        {% render 'boc-responsive-image',
          image: section.settings.image,
          mobile_image: section.settings.mobile_image,
          alt: section.settings.image.alt | default: section.settings.heading,
          loading: 'lazy',
          sizes: '(min-width: 1050px) 55vw, 100vw'
        %}
      {%- else -%}
        <img src="{{ image_url }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="1600" height="680">
      {%- endif -%}
    </div>

    <div class="boc-wine-club-estate__copy" style="background: {{ section.settings.copy_background_color | default: '#B99E7E' }};">
      {%- if section.settings.eyebrow != blank -%}
        <span class="boc-eyebrow boc-wine-club-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="boc-wine-club-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="boc-wine-club-section__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="boc-wine-club-estate__checks">
          {%- for block in section.blocks -%}
            {%- if block.settings.text != blank -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
        {% render 'boc-button',
          label: section.settings.button_label,
          url: section.settings.button_link | default: '/pages/visit',
          style: section.settings.button_style | default: 'light',
          new_tab: section.settings.button_new_tab
        %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — Wine Club Estate",
  "tag": "section",
  "class": "boc-wine-club-estate-section",
  "max_blocks": 8,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    {
      "type": "select",
      "id": "image_side",
      "label": "Image side",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_stack_order",
      "label": "Mobile stacking order",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "copy_first", "label": "Copy first" }
      ],
      "default": "image_first"
    },
    { "type": "text", "id": "split_ratio", "label": "Split ratio (CSS grid)", "default": "1.08fr 0.92fr" },
    { "type": "range", "id": "desktop_image_height", "label": "Desktop image height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 680 },
    { "type": "range", "id": "mobile_image_height", "label": "Mobile image height", "min": 280, "max": 600, "step": 20, "unit": "px", "default": 380 },
    { "type": "color", "id": "background_color", "label": "Background colour", "default": "#FFFFFF" },
    { "type": "color", "id": "copy_background_color", "label": "Copy panel background", "default": "#B99E7E" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#FFFFFF" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "At the estate" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your invitation to come closer." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Wine club membership is about more than what arrives at your door. It is a way to stay connected to the people, vineyards and stories behind each bottle." },
    { "type": "header", "content": "Button" },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Plan your visit" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "light", "label": "Light outline" },
        { "value": "accent", "label": "Accent" },
        { "value": "primary", "label": "Primary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "light"
    },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "text", "label": "Benefit line", "default": "Benefit line" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Wine Club Estate",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Complimentary cellar door tastings" } },
        { "type": "benefit", "settings": { "text": "Exclusive member events and release previews" } },
        { "type": "benefit", "settings": { "text": "Priority bookings for selected experiences" } },
        { "type": "benefit", "settings": { "text": "Personal support from our wine club team" } }
      ]
    }
  ]
}
{% endschema %}
