{%- doc -%}
  Renders a Visit menu card block.

  @param {object} block - Menu card block
  @param {object} settings - Section settings
{%- enddoc -%}

{%- liquid
  assign card_url = '#'
  assign open_new_tab = block.settings.open_new_tab

  if block.settings.link_type == 'page' and block.settings.page != blank
    assign card_url = block.settings.page.url
  elsif block.settings.link_type == 'file' and block.settings.file_url != blank
    assign card_url = block.settings.file_url
    assign open_new_tab = true
  elsif block.settings.url != blank
    assign card_url = block.settings.url
  endif

  assign fallback_image = 'boc-estate-visit.jpg' | asset_url
  assign card_height = block.settings.card_height | default: settings.default_card_height | default: 520
-%}

<a
  href="{{ card_url }}"
  class="boc-visit-menu-card"
  style="--boc-v-menu-h: {{ card_height }}px; --boc-v-menu-overlay: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
  {% if open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
  {{ block.shopify_attributes }}
>
  <div class="boc-visit-menu-card__media">
    {%- if block.settings.image != blank -%}
      {% render 'boc-responsive-image',
        image: block.settings.image,
        mobile_image: block.settings.mobile_image,
        alt: block.settings.image.alt | default: block.settings.heading,
        loading: 'lazy',
        sizes: '(min-width: 980px) 50vw, 100vw'
      %}
    {%- else -%}
      <img src="{{ fallback_image }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1200" height="520">
    {%- endif -%}
  </div>
  <div class="boc-visit-menu-card__overlay" aria-hidden="true"></div>
  <div class="boc-visit-menu-card__copy">
    {%- if block.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ block.settings.eyebrow }}</span>{%- endif -%}
    {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
    {%- if block.settings.description != blank -%}<p>{{ block.settings.description }}</p>{%- endif -%}
    {%- if block.settings.link_label != blank -%}
      <span class="boc-btn boc-btn--light">{{ block.settings.link_label }}</span>
    {%- endif -%}
  </div>
</a>
