{%- liquid
  assign section_classes = 'boc-wine-club-section boc-wine-club-final-cta boc-wine-club-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-wine-club-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-wine-club-section--hide-mobile'
  endunless

  assign image_fallback = 'boc-estate-vineyard.jpg' | asset_url
-%}

<section
  id="boc-wine-club-final-cta-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-wine-club
  style="
    --boc-wc-bg-fallback: {{ section.settings.background_color }};
    --boc-wc-overlay: {{ section.settings.overlay_color }};
    --boc-wc-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-wc-final-min-h: {{ section.settings.height_desktop }}px;
    --boc-wc-final-min-h-m: {{ section.settings.height_mobile }}px;
    --boc-wc-content-width: {{ section.settings.content_width }}px;
    --boc-wc-align-d: {{ section.settings.text_alignment_desktop }};
    --boc-wc-align-m: {{ section.settings.text_alignment_mobile }};
    --boc-wc-heading: {{ section.settings.heading_color }};
    --boc-wc-body: {{ section.settings.body_color }};
    --boc-wc-btn-bg: {{ section.settings.button_bg_color }};
    --boc-wc-btn-text: {{ section.settings.button_text_color }};
    --boc-wc-btn-border: {{ section.settings.button_border_color }};
    --boc-wc-btn-hover-bg: {{ section.settings.button_hover_bg_color }};
    --boc-wc-btn-hover-text: {{ section.settings.button_hover_text_color }};
    --boc-wc-btn-hover-border: {{ section.settings.button_hover_border_color }};
  "
>
  <div class="boc-wine-club-final-cta__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image',
        image: section.settings.image,
        mobile_image: section.settings.mobile_image,
        alt: section.settings.image.alt | default: section.settings.heading,
        loading: 'lazy',
        sizes: '100vw'
      %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="2400" height="620">
    {%- endif -%}
  </div>
  <div class="boc-wine-club-final-cta__overlay" aria-hidden="true"></div>

  <div class="boc-container boc-wine-club-final-cta__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="boc-eyebrow boc-wine-club-section__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="boc-wine-club-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="boc-wine-club-section__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.settings.button_enabled and section.settings.button_label != blank -%}
      <div class="boc-wine-club-final-cta__actions">
        <a
          href="{{ section.settings.button_link | default: '/pages/contact' }}"
          class="boc-btn boc-btn--{{ section.settings.button_style }} boc-wine-club-btn--custom"
          {% if section.settings.button_new_tab %}
            target="_blank"
            rel="noopener noreferrer"
          {% endif %}
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BOC — Wine Club Final CTA",
  "tag": "section",
  "class": "boc-wine-club-final-cta-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile background image" },
    { "type": "color", "id": "background_color", "label": "Background colour fallback", "default": "#333333" },
    { "type": "color", "id": "overlay_color", "label": "Overlay colour", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 45 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 620 },
    { "type": "range", "id": "height_mobile", "label": "Mobile height", "min": 360, "max": 800, "step": 20, "unit": "px", "default": 560 },
    { "type": "range", "id": "content_width", "label": "Content max width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 760 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to join?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Make Boat O'Craigo part of your cellar." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Speak with our team for help finding the right wine club option for your cellar." },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#FFFFFF" },
    { "type": "color", "id": "body_color", "label": "Body colour", "default": "#FFFFFF" },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Desktop alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Mobile alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Button" },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact the team" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "light", "label": "Light outline" },
        { "value": "accent", "label": "Accent" },
        { "value": "primary", "label": "Primary" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "light"
    },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false },
    { "type": "color", "id": "button_bg_color", "label": "Button background", "default": "#000000" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_border_color", "label": "Button border", "default": "#FFFFFF" },
    { "type": "color", "id": "button_hover_bg_color", "label": "Hover background", "default": "#FFFFFF" },
    { "type": "color", "id": "button_hover_text_color", "label": "Hover text", "default": "#212121" },
    { "type": "color", "id": "button_hover_border_color", "label": "Hover border", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "BOC — Wine Club Final CTA" }]
}
{% endschema %}
