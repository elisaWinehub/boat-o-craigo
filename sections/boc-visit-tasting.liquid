{%- liquid
  assign section_classes = 'boc-visit-section boc-visit-tasting boc-visit-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-visit-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-visit-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-visit-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-visit-section--hide-mobile'
  endunless
-%}

<section
  id="boc-visit-tasting-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-visit
>
  {% render 'boc-feature-split',
    section: section,
    anchor_id: section.settings.section_anchor_id | default: 'boc-visit-tasting',
    reverse: false,
    dark_copy: false,
    image_fallback: 'boc-hero-wines.png'
  %}
</section>

{% schema %}
{
  "name": "BOC — Visit Tasting",
  "tag": "section",
  "class": "boc-visit-tasting-section",
  "max_blocks": 8,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "section_anchor_id", "label": "Section anchor ID", "default": "boc-visit-tasting" },
    { "type": "url", "id": "booking_url", "label": "Tasting booking URL", "default": "/pages/book-now" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "text", "id": "split_ratio", "label": "Split ratio", "default": "1.05fr 0.95fr" },
    { "type": "range", "id": "desktop_image_height", "label": "Desktop image height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 680 },
    { "type": "range", "id": "tablet_image_height", "label": "Tablet image height", "min": 300, "max": 700, "step": 20, "unit": "px", "default": 520 },
    { "type": "range", "id": "mobile_image_height", "label": "Mobile image height", "min": 280, "max": 600, "step": 20, "unit": "px", "default": 380 },
    { "type": "select", "id": "mobile_stack_order", "label": "Mobile stack order", "options": [{"value":"image_first","label":"Image first"},{"value":"copy_first","label":"Copy first"}],"default": "image_first" },
    { "type": "color", "id": "copy_background_color", "label": "Copy background", "default": "#FAF8F5" },
    { "type": "color", "id": "copy_text_color", "label": "Copy text", "default": "#212121" },
    { "type": "color", "id": "copy_body_color", "label": "Body text", "default": "#575962" },
    { "type": "color", "id": "detail_border_color", "label": "Detail border", "default": "#E8E2D9" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Cellar door" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Taste the estate." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Discover a guided selection of premium wines made from our two Yarra Valley vineyard sites. Our team will take you through the stories, seasons and winemaking behind each glass." },
    { "type": "checkbox", "id": "button_enabled", "label": "Enable button", "default": true },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Book a tasting" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"primary","label":"Primary"},{"value":"light","label":"Light"}],"default": "primary" },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open in new tab", "default": false }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Detail" },
        { "type": "text", "id": "value", "label": "Value", "default": "Value" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BOC — Visit Tasting",
      "blocks": [
        { "type": "detail", "settings": { "label": "Classic tasting", "value": "5 wines" } },
        { "type": "detail", "settings": { "label": "Duration", "value": "Approx. 45 minutes" } },
        { "type": "detail", "settings": { "label": "Walk-ins", "value": "Welcome when available" } },
        { "type": "detail", "settings": { "label": "Bookings", "value": "Recommended" } }
      ]
    }
  ]
}
{% endschema %}
