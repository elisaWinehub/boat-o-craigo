{%- doc -%}
  Featured team profile card for About team section.

  @param {object} block - Team member block
  @param {string} section_id - Parent section ID
  @param {string} [image_fallback] - Fallback asset
{%- enddoc -%}

{%- liquid
  assign fallback_url = image_fallback | default: 'boc-estate-vineyard.jpg' | asset_url
  assign alt_text = block.settings.image.alt | default: block.settings.name
  if block.settings.image == blank
    assign alt_text = block.settings.name | append: ' placeholder portrait'
  endif
-%}

<button
  type="button"
  class="boc-about-team__featured-card"
  data-boc-about-team-open="{{ block.id }}"
  aria-label="View profile for {{ block.settings.name | escape }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.image != blank or block.settings.mobile_image != blank -%}
    {% render 'boc-responsive-image',
      image: block.settings.image,
      mobile_image: block.settings.mobile_image,
      alt: alt_text,
      loading: 'lazy',
      sizes: '(min-width: 980px) 50vw, 100vw'
    %}
  {%- else -%}
    <img src="{{ fallback_url }}" alt="{{ alt_text | escape }}" loading="lazy" width="800" height="540">
  {%- endif -%}
  <span class="boc-about-team__featured-copy">
    {%- if block.settings.name != blank -%}<h3>{{ block.settings.name }}</h3>{%- endif -%}
    {%- if block.settings.role != blank -%}<span class="boc-about-team__role">{{ block.settings.role }}</span>{%- endif -%}
    {%- if block.settings.summary != blank -%}<p>{{ block.settings.summary }}</p>{%- endif -%}
    <span class="boc-about-team__more">View profile</span>
  </span>
</button>
