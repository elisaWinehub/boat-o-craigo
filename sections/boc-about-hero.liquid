{%- liquid
  assign section_classes = 'boc-about-section boc-about-hero boc-about-section--full'
  unless section.settings.section_enabled
    assign section_classes = section_classes | append: ' boc-about-section--disabled'
  endunless
  unless section.settings.show_desktop
    assign section_classes = section_classes | append: ' boc-about-section--hide-desktop'
  endunless
  unless section.settings.show_tablet
    assign section_classes = section_classes | append: ' boc-about-section--hide-tablet'
  endunless
  unless section.settings.show_mobile
    assign section_classes = section_classes | append: ' boc-about-section--hide-mobile'
  endunless
  assign image_fallback = 'boc-estate-vineyard.jpg' | asset_url
  assign family_anchor = section.settings.family_anchor | default: 'boc-about-family'
  assign careers_anchor = section.settings.careers_anchor | default: 'boc-about-careers'
-%}

{{ 'boc-about.css' | asset_url | stylesheet_tag }}
<script src="{{ 'boc-about.js' | asset_url }}" defer></script>

<section
  id="boc-about-hero-{{ section.id }}"
  class="{{ section_classes }}"
  data-boc-about
  style="
    --boc-ab-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --boc-ab-hero-min-h: {{ section.settings.height_desktop }}px;
    --boc-ab-hero-min-h-t: {{ section.settings.height_tablet }}px;
    --boc-ab-hero-min-h-m: {{ section.settings.height_mobile }}px;
    --boc-ab-focal: {{ section.settings.image_focal_point }};
    --boc-ab-content-width: {{ section.settings.content_width }}px;
    --boc-ab-align-d: {{ section.settings.text_alignment_desktop }};
    --boc-ab-align-m: {{ section.settings.text_alignment_mobile }};
  "
>
  <div class="boc-about-hero__media">
    {%- if section.settings.image != blank -%}
      {% render 'boc-responsive-image', image: section.settings.image, mobile_image: section.settings.mobile_image, alt: section.settings.heading, loading: 'eager', sizes: '100vw' %}
    {%- else -%}
      <img src="{{ image_fallback }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="2400" height="720">
    {%- endif -%}
  </div>
  <div class="boc-about-hero__overlay" aria-hidden="true"></div>
  <div class="boc-about-hero__content">
    {%- if section.settings.eyebrow != blank -%}<span class="boc-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h1 class="boc-about-section__heading">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.body != blank -%}<p>{{ section.settings.body }}</p>{%- endif -%}
    <div class="boc-about-hero__actions">
      {%- if section.settings.button_1_enabled and section.settings.button_1_label != blank -%}
        <a href="#{{ family_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_1_style }}" data-boc-about-scroll>{{ section.settings.button_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_enabled and section.settings.button_2_label != blank -%}
        <a href="#{{ careers_anchor }}" class="boc-btn boc-btn--{{ section.settings.button_2_style }}" data-boc-about-scroll>{{ section.settings.button_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BOC — About Hero",
  "tag": "section",
  "class": "boc-about-hero-section",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Enable section", "default": true },
    { "type": "checkbox", "id": "show_desktop", "label": "Show on desktop", "default": true },
    { "type": "checkbox", "id": "show_tablet", "label": "Show on tablet", "default": true },
    { "type": "checkbox", "id": "show_mobile", "label": "Show on mobile", "default": true },
    { "type": "text", "id": "family_anchor", "label": "Family section anchor", "default": "boc-about-family" },
    { "type": "text", "id": "careers_anchor", "label": "Careers section anchor", "default": "boc-about-careers" },
    { "type": "image_picker", "id": "image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "height_desktop", "label": "Desktop height", "min": 400, "max": 1000, "step": 20, "unit": "px", "default": 720 },
    { "type": "range", "id": "height_tablet", "label": "Tablet height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 620 },
    { "type": "range", "id": "height_mobile", "label": "Mobile height", "min": 360, "max": 800, "step": 20, "unit": "px", "default": 600 },
    { "type": "select", "id": "image_focal_point", "label": "Image focal point", "options": [{"value":"center","label":"Center"},{"value":"62% center","label":"Mobile crop"}],"default": "center" },
    { "type": "range", "id": "content_width", "label": "Content max width", "min": 480, "max": 960, "step": 20, "unit": "px", "default": 780 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rooted in family. Shaped by place." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Discover the family, vineyards, winemakers and people behind Boat O'Craigo—an independent Yarra Valley estate built around thoughtful wine, genuine hospitality and two distinctive vineyard sites." },
    { "type": "select", "id": "text_alignment_desktop", "label": "Desktop alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default": "left" },
    { "type": "select", "id": "text_alignment_mobile", "label": "Mobile alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}],"default": "left" },
    { "type": "header", "content": "Primary button" },
    { "type": "checkbox", "id": "button_1_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_1_label", "label": "Label", "default": "Discover our story" },
    { "type": "select", "id": "button_1_style", "label": "Style", "options": [{"value":"accent","label":"Accent"},{"value":"light","label":"Light"}],"default": "accent" },
    { "type": "header", "content": "Secondary button" },
    { "type": "checkbox", "id": "button_2_enabled", "label": "Enable", "default": true },
    { "type": "text", "id": "button_2_label", "label": "Label", "default": "Work with us" },
    { "type": "select", "id": "button_2_style", "label": "Style", "options": [{"value":"light","label":"Light"},{"value":"accent","label":"Accent"}],"default": "light" }
  ],
  "presets": [{ "name": "BOC — About Hero" }]
}
{% endschema %}
