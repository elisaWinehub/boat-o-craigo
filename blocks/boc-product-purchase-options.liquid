{%- liquid
  assign product = closest.product | default: product
  assign variant = product.selected_or_first_available_variant
  assign has_plans = false
  if product.selling_plan_groups.size > 0
    assign has_plans = true
  endif
  assign option_name = 'purchase-option-' | append: section.id
-%}

<div class="purchase-options" data-block-type="selling-plans" data-boc-purchase-options {{ block.shopify_attributes }}>
  <label class="purchase-option active" data-boc-purchase-option>
    <input type="radio" name="{{ option_name }}" value="one-time" checked data-boc-purchase-radio>
    <span>
      <span class="purchase-option-title">{{ block.settings.one_time_title | default: 'One-time purchase' }}</span>
      <span class="purchase-option-copy">{{ block.settings.one_time_copy }}</span>
    </span>
    <span class="purchase-option-price">{% render 'format-price', price: variant.price %}</span>
  </label>

  {%- if has_plans -%}
    {%- assign first_plan = product.selling_plan_groups.first.selling_plans.first -%}
    {%- assign plan_price = variant.price -%}
    {%- for allocation in variant.selling_plan_allocations -%}
      {%- if allocation.selling_plan.id == first_plan.id -%}
        {%- assign plan_price = allocation.price -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    <label class="purchase-option" data-boc-purchase-option>
      <input
        type="radio"
        name="{{ option_name }}"
        value="subscription"
        data-boc-purchase-radio
        data-selling-plan-id="{{ first_plan.id }}"
      >
      <span>
        <span class="purchase-option-title">{{ block.settings.subscription_title | default: 'Subscribe & save' }}</span>
        <span class="purchase-option-copy">{{ block.settings.subscription_copy }}</span>
      </span>
      <span class="purchase-option-price">{% render 'format-price', price: plan_price %}</span>
    </label>

    <div class="subscription-placeholder" data-boc-subscription-panel>
      <label for="subscriptionFrequency-{{ section.id }}">{{ block.settings.frequency_label | default: 'Delivery frequency' }}</label>
      <select id="subscriptionFrequency-{{ section.id }}" data-boc-selling-plan-select>
        {%- for group in product.selling_plan_groups -%}
          {%- for plan in group.selling_plans -%}
            <option value="{{ plan.id }}">{{ plan.name }}</option>
          {%- endfor -%}
        {%- endfor -%}
      </select>
    </div>

  {%- elsif block.settings.show_static_subscription -%}
    {%- liquid
      assign static_save_pct = block.settings.static_save_pct | default: 10
    -%}
    <label class="purchase-option purchase-option--static" data-boc-purchase-option>
      <input
        type="radio"
        name="{{ option_name }}"
        value="subscription"
        data-boc-purchase-radio
        data-selling-plan-static="true"
      >
      <span>
        <span class="purchase-option-title">{{ block.settings.subscription_title | default: 'Subscribe & save' }} {{ static_save_pct }}%</span>
        <span class="purchase-option-copy">{{ block.settings.subscription_copy | default: 'Curated quarterly delivery. Cancel any time.' }}</span>
      </span>
      <span class="purchase-option-price">
        {%- assign discounted = variant.price | times: 100 | minus: static_save_pct | divided_by: 100 -%}
        {{ discounted | money }}
      </span>
    </label>

    <div class="subscription-placeholder" data-boc-subscription-panel>
      <label for="subscriptionFrequency-{{ section.id }}">{{ block.settings.frequency_label | default: 'Delivery frequency' }}</label>
      <select id="subscriptionFrequency-{{ section.id }}">
        <option value="monthly">{{ block.settings.freq_monthly | default: 'Every month' }}</option>
        <option value="bimonthly">{{ block.settings.freq_bimonthly | default: 'Every 2 months' }}</option>
        <option value="quarterly">{{ block.settings.freq_quarterly | default: 'Every 3 months (quarterly)' }}</option>
      </select>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "BOC — Purchase options",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "one_time_title",
      "label": "One-time title",
      "default": "One-time purchase"
    },
    {
      "type": "textarea",
      "id": "one_time_copy",
      "label": "One-time description",
      "default": "Single bottle purchase at the standard price."
    },
    {
      "type": "text",
      "id": "subscription_title",
      "label": "Subscription fallback title",
      "default": "Subscribe & save"
    },
    {
      "type": "textarea",
      "id": "subscription_copy",
      "label": "Subscription description"
    },
    {
      "type": "text",
      "id": "frequency_label",
      "label": "Frequency label",
      "default": "Delivery frequency"
    },
    {
      "type": "header",
      "content": "Static subscription fallback"
    },
    {
      "type": "checkbox",
      "id": "show_static_subscription",
      "label": "Show static subscribe option",
      "default": true,
      "info": "Displays a visual subscribe option when no Shopify selling plans are installed. This does not process real subscriptions — it is a UI placeholder until a subscription app (e.g. Recharge, WineHub) is connected."
    },
    {
      "type": "range",
      "id": "static_save_pct",
      "label": "Displayed discount %",
      "min": 5,
      "max": 30,
      "step": 5,
      "default": 10
    },
    {
      "type": "text",
      "id": "freq_monthly",
      "label": "Frequency option 1",
      "default": "Every month"
    },
    {
      "type": "text",
      "id": "freq_bimonthly",
      "label": "Frequency option 2",
      "default": "Every 2 months"
    },
    {
      "type": "text",
      "id": "freq_quarterly",
      "label": "Frequency option 3",
      "default": "Every 3 months (quarterly)"
    }
  ],
  "presets": [
    {
      "name": "BOC — Purchase options",
      "category": "Product"
    }
  ]
}
{% endschema %}
