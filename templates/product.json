{
  "sections": {
    "main": {
      "type": "boc-main-product",
      "blocks": {
        "kicker": {
          "type": "boc-product-kicker",
          "settings": {
            "kicker_source": "vendor",
            "vintage_prefix": "Vintage"
          }
        },
        "title": {
          "type": "boc-product-title",
          "settings": {}
        },
        "subtitle": {
          "type": "boc-product-subtitle",
          "settings": {
            "prefix": "Estate grown"
          }
        },
        "rating": {
          "type": "boc-product-rating",
          "settings": {
            "reviews_label": "reviews",
            "static_enabled": true,
            "static_stars": "★★★★★",
            "static_score": "4.9",
            "static_count": "18"
          }
        },
        "price": {
          "type": "boc-product-price",
          "settings": {
            "show_savings": true
          }
        },
        "short_copy": {
          "type": "boc-product-short-copy",
          "settings": {
            "source": "description"
          }
        },
        "meta_list": {
          "type": "boc-product-meta-list",
          "settings": {}
        },
        "purchase_options": {
          "type": "boc-product-purchase-options",
          "settings": {
            "one_time_title": "One-time purchase",
            "one_time_copy": "Single bottle purchase at the standard price.",
            "subscription_title": "Subscribe & save",
            "frequency_label": "Delivery frequency",
            "show_static_subscription": true,
            "static_save_pct": 10,
            "freq_monthly": "Every month",
            "freq_bimonthly": "Every 2 months",
            "freq_quarterly": "Every 3 months (quarterly)"
          }
        },
        "form": {
          "type": "boc-product-form",
          "settings": {
            "button_label": "Add to cart"
          }
        },
        "secondary_cta": {
          "type": "boc-product-secondary-cta",
          "settings": {
            "label": "Join Wine Club & Save More",
            "url": "shopify://pages/wine-club"
          }
        },
        "stock": {
          "type": "boc-product-stock",
          "settings": {}
        },
        "benefits": {
          "type": "boc-product-benefits",
          "settings": {}
        },
        "accordions": {
          "type": "boc-product-accordions",
          "blocks": {
            "tasting": {
              "type": "boc-product-accordion-item",
              "settings": {
                "heading": "Tasting notes",
                "accordion_type": "tasting_notes",
                "open_by_default": true
              }
            },
            "details": {
              "type": "boc-product-accordion-item",
              "settings": {
                "heading": "Wine details",
                "accordion_type": "wine_details",
                "cellaring_source": "ageing_process"
              }
            },
            "pairing": {
              "type": "boc-product-accordion-item",
              "settings": {
                "heading": "Food pairing",
                "accordion_type": "food_pairing"
              }
            },
            "shipping": {
              "type": "boc-product-accordion-item",
              "settings": {
                "heading": "Shipping & delivery",
                "accordion_type": "shipping",
                "content": "<p>Orders are packed securely and dispatched from the winery. Delivery estimates and free-shipping thresholds are set in Shopify shipping settings.</p>"
              }
            },
            "pdf": {
              "type": "boc-product-accordion-item",
              "settings": {
                "heading": "Download wine information",
                "accordion_type": "pdf_download",
                "link_label": "Download PDF"
              }
            }
          },
          "block_order": ["tasting", "details", "pairing", "shipping", "pdf"]
        }
      },
      "block_order": [
        "kicker",
        "title",
        "subtitle",
        "rating",
        "price",
        "short_copy",
        "meta_list",
        "purchase_options",
        "form",
        "secondary_cta",
        "stock",
        "benefits",
        "accordions"
      ],
      "settings": {
        "wines_label": "Wines"
      }
    },
    "story": {
      "type": "boc-product-story",
      "settings": {
        "eyebrow": "From the vineyard",
        "heading": "Cool climate. Bright character.",
        "copy_background_color": "#171717",
        "vineyard_label": "Vineyard",
        "region_label": "Region",
        "winemaker_label": "Winemaking"
      }
    },
    "related": {
      "type": "boc-product-related",
      "settings": {
        "recommendation_type": "related",
        "max_products": 4,
        "eyebrow": "You may also enjoy",
        "heading": "Related wines.",
        "link_label": "View all wines"
      }
    }
  },
  "order": ["main", "story", "related"]
}
